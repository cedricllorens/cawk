# -----------------------------------------------------------------------
# This script checks that a cawk test code is compliant with
# internal coding rules
#  in case of error, start print message with cawk test error: and to end with NOK
#  in case of success, start print message with cawk test pass : and to end with OK
# -----------------------------------------------------------------------

# FIX 1: removed dead code
# FIX 5: FIXED Point 2 - now tracks variable initialization in BEGINFILE
# FIX 6: FIXED Point 4 - now tracks arrays used and deleted in BEGINFILE
# FIX 8: IMPROVED DEBUG detection (case-insensitive)
# FIX 9: ADDED risk_level validation for print_err() calls
# DISABLED: Point 5 (function call tracking) - generates too many false positives

function count_func_args(line, open_paren_pos,    depth, i, char, count, len, content) {
    depth = 1
    count = 0
    content = ""
    len = length(line)
    for (i = open_paren_pos + 1; i <= len; i++) {
        char = substr(line, i, 1)
        if (char == "(") {
            depth++
            content = content char
        } else if (char == ")") {
            depth--
            if (depth == 0) break
            content = content char
        } else if (char == "," && depth == 1) {
            count++
            content = content char
        } else {
            content = content char
        }
    }
    # if content between parens is empty or whitespace only, no arguments
    if (content ~ /^[[:space:]]*$/) {
        return 0
    }
    return count + 1
}

BEGINFILE {
    # extract just the file name (without path)
    n = split(FILENAME, parts, "/")
    filename = parts[n]

    error_count = 0
    in_beginfile_block = 0

    # tracking for Point 2, 4
    delete vars_initialized_in_beginfile
    delete arrays_in_beginfile
    delete arrays_deleted_in_beginfile
}

{
    # skip empty lines and comments
    if ($0 ~ /^[[:space:]]*$/ || $0 ~ /^[[:space:]]*#/) {
        next
    }

    # track if we are in BEGINFILE block
    if (match($0, /^[[:space:]]*BEGINFILE\s*{/)) {
        in_beginfile_block = 1
        next
    }
    if (in_beginfile_block && match($0, /^[[:space:]]*}/)) {
        in_beginfile_block = 0
        next
    }

    # ========== MAIN VALIDATION RULES ==========

    # detect the first argument of print_err("xxx", ...), it must match filename
    if (match($0, /print_err\("([^"]+)"/, m)) {
        arg = m[1]
        if (filename != arg) {
            print "cawk test error: file=" filename " print_err=" arg " (in "FILENAME" line "FNR") NOK"
            error_count++
        }
    }

    # FIX 9: Validate risk_level and status_code in print_err() — only quoted string literals
    # Pattern: print_err("test_name", "message or message_expr", line_num, "risk_level", "status_code")
    # This regex captures the 4th and 5th arguments (risk_level and status_code) as quoted strings
    if (match($0, /print_err\s*\([^,]+,\s*[^,]+,\s*[^,]+\s*,\s*"([a-z]+)"\s*,\s*"([a-z]+)"/, m)) {
        risk_level = m[1]
        status_code = m[2]

        if (risk_level !~ /^(high|medium|low|info)$/) {
            print "cawk test error: invalid risk_level=\""risk_level"\" in print_err call (must be one of: high, medium, low, info) (in "FILENAME" line "FNR") NOK"
            error_count++
        }

        if (status_code !~ /^(pass|error|warning|psirt)$/) {
            print "cawk test error: invalid status_code=\""status_code"\" in print_err call (must be one of: pass, error, warning, psirt) (in "FILENAME" line "FNR") NOK"
            error_count++
        }
    }

    # FIX 8: detect if a debug trace has been left in the code (case-insensitive)
    if (match(tolower($0), /debug/)) {
        # skip if it's in a comment
        # skip if it's a case label (case debug: in switch statement)
        if (!match($0, /^[[:space:]]*#/) && !match($0, /case\s+/)) {
            print "cawk test error: debug trace has been found "$0" (in "FILENAME" line "FNR") NOK"
            error_count++
        }
    }

    # detect comparison instead of assignation (== instead of =)
    # pattern: word == digit; (standalone statement)
    if (match($0, /^\s*(\w+)\s*==\s*[0-9];\s*$/, m)) {
        print "cawk test error: comparison instead of assignation: "$0" (in "FILENAME" line "FNR") NOK"
        error_count++
    }

    # detect typos in variable names (eexception_*, ppass_*, etc.)
    if (match($0, /(eexception|ppass|eextra|aarray|bblock|pprint|nnext|ddelete)/, m)) {
        print "cawk test error: typo in variable name: "$0" (in "FILENAME" line "FNR") NOK"
        error_count++
    }

    # detect regex pattern without block (pattern { missing)
    # pattern: /^regex$/ && /^regex$/ without following {
    if (match($0, /\/\^[^\/]+\/\$\s*&&\s*\/\^[^\/]+\/\$\s*[^{]*$/, m)) {
        print "cawk test error: regex pattern without block { : "$0" (in "FILENAME" line "FNR") NOK"
        error_count++
    }

    # FIX 5: Point 2 - track variable initialization in BEGINFILE
    if (in_beginfile_block) {
        # detect assignments: var = value, pass = ..., block_xxx = ...
        if (match($0, /^\s*([a-zA-Z_]\w*)\s*=/, m)) {
            var_name = m[1]
            vars_initialized_in_beginfile[var_name] = 1
        }
        # FIX 6: detect array usage: array[...]
        if (match($0, /\b([a-zA-Z_]\w*)\[/, m)) {
            array_name = m[1]
            arrays_in_beginfile[array_name] = 1
        }
        # FIX 6: detect array deletion: delete array
        if (match($0, /delete\s+([a-zA-Z_]\w*)/, m)) {
            array_name = m[1]
            arrays_deleted_in_beginfile[array_name] = 1
        }
    }

    # check if variables pass/block_* are used without proper initialization
    if (match($0, /\b(pass|block_\w+|error)\b/, m)) {
        var_used = m[1]
        if (!(var_used in vars_initialized_in_beginfile) && !in_beginfile_block) {
            # only warn if not in BEGINFILE block (we initialize there)
            # print "cawk test warning: variable '"var_used"' may be used without initialization (in "FILENAME" line "FNR")"
        }
    }

    # Point 5: DISABLED - function tracking generates too many false positives
    # (cannot reliably distinguish between function calls and other constructs)
    # The pattern-based approach fails on if/while/for statements and nested structures
}

ENDFILE {
    # FIX 6: Point 4 - check if arrays used in BEGINFILE are properly deleted
    for (array_name in arrays_in_beginfile) {
        # skip known internal arrays
        if (array_name ~ /^(parts|args_array|sig_parts|other_parts|m)$/) {
            continue
        }
        if (!(array_name in arrays_deleted_in_beginfile)) {
            print "cawk test error: array '"array_name"' is used but not deleted (in "FILENAME") NOK"
            error_count++
        }
    }

    # Final report - only show pass message if no errors
    if (error_count == 0) {
        print "cawk test pass : "FILENAME" OK"
    }
}

END {
}
