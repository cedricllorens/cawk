#
# @test_name : services_sshv1_notset.juniper-junos.gawk
# @supplier : juniper-junos
# @purpose : check if <ssh version v1> is not set
# @description : ssh version v1 is insecure and should not be enabled for remote management
# @actions : ensure ssh protocol-version is set to v2 only or configure protocol-version to exclude v1 (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-13 | System and Communications Protection | Ensure cryptographic protection is used for data in transit
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	block_system = 0;
	block_services = 0;
	block_ssh = 0;
	found_ssh = 0;
	pass = 1;
}

/^system {/ {
        block_system = 1;
	next;
}

/^%SED_BK_JUNI%services {/ && block_system == 1 {
	block_services = 1;
	next;
}

/^%SED_BK_JUNI%{2}ssh {/ && block_services == 1 {
	block_ssh = 1;
	found_ssh = 1;
	next;
}

/^%SED_BK_JUNI%{3}protocol-version/ && block_ssh == 1 {
	if (/v1/) {
		print_err("services_sshv1_notset.juniper-junos.gawk",rm_blank_before($0),FNR,"high","error");
		pass = 0;
	}
	next;
}

/^%SED_BK_JUNI%{2}}$/ && block_ssh == 1 {
	block_ssh = 0;
	next;
}

/^%SED_BK_JUNI%}$/ && block_services == 1 {
	block_services = 0;
	next;
}

/^}$/ {
	block_system = 0;
}

ENDFILE {
	if ( pass && found_ssh ) {
		print_err("services_sshv1_notset.juniper-junos.gawk","ssh version v1 is not set",0,"high","pass");
	} else if ( !found_ssh ) {
		print_err("services_sshv1_notset.juniper-junos.gawk","ssh service not found",0,"high","error");
	}
}

END {
}
