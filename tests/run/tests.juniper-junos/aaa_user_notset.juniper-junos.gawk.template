#
# @test_name : aaa_user_notset.juniper-junos
# @supplier : juniper-junos
# @purpose : check that <aaa forbidden users> are not set
# @description : presence of forbidden aaa users indicates unauthorized or default accounts that should be removed
# @actions : remove forbidden aaa users and enforce least-privilege account management (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.1.3 | Ensure local users are minimized | Authentication, Authorization & Accounting
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
}

/^system {/ && block_system == 0 {
	block_system = 1;
	block_login = 0;
	next;
}

/^%SED_BK_JUNI%login/ && block_system == 1 {
	block_login = 1;
	next;	
}

/^%SED_BK_JUNI%{2}user/ && !/user %SED_AUTHUSER_JUNI%/ && block_login == 1 {
	print_err("aaa_user_notset.juniper-junos.gawk",rm_blank_before($0),FNR,"high","error");
        pass = 0;
	next;	
}

/^%SED_BK_JUNI%}$/ && block_login == 1 {
	block_login = 0;
}

/^}$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( pass ) print_err("aaa_user_notset.juniper-junos.gawk","aaa forbidden users are not set",0,"high","pass");
}

END {
}
