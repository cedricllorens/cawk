#
# @test_name : ntp_restrict_set.juniper-junos.gawk
# @supplier : juniper-junos
# @purpose : check if <ntp restrict> is set
# @description : missing ntp restrict rules means unauthorized hosts could synchronize ntp time and perform time-based attacks
# @actions : configure ntp restrict statements to limit ntp query and modification access (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-23 | System and Communications Protection | Ensure session authenticity is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	block_system = 0;
	block_ntp = 0;
	pass = 0;
}

/^system {/ {
        block_system = 1;
	next;
}

/^%SED_BK_JUNI%ntp {/ && block_system == 1 {
	block_ntp = 1;
	next;
}

/^%SED_BK_JUNI%{2}restrict/ && block_ntp == 1 {
	print_err("ntp_restrict_set.juniper-junos.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 1;
	nextfile;
}

/^%SED_BK_JUNI%}$/ && block_ntp == 1 {
	block_ntp = 0;
	next;
}

/^}$/ {
	block_system = 0;
}

ENDFILE {
	if ( !pass ) print_err("ntp_restrict_set.juniper-junos.gawk","ntp restrict is not set",0,"high","error");
}

END {
}
