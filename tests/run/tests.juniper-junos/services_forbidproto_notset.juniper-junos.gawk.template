#
# @test_name : services_forbidproto_notset.juniper-junos
# @supplier : juniper-junos
# @purpose : check if <services block> has not setup forbidden protocols
# @description : forbidden protocols enabled in the services block expose the device to insecure management access
# @actions : remove forbidden protocols from the services block and restrict to ssh only (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.1 | Ensure unnecessary services are disabled | Services
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	block_system = 0;
	block_services = 0;
	pass = 1;
}

/^system {/ {
        block_system = 1;
	next;
}

/^%SED_BK_JUNI%services {/ && block_system == 1 {
	block_services = 1;
	next;
}

/^%SED_BK_JUNI%{2}%SED_MGNT_BADPROTO%( |;)/ && block_services == 1 {
	print_err("services_forbidproto_notset.juniper-junos.gawk",rm_last_char(rm_blank_before($0)),FNR,"high","error");
	pass = 0;
	next;
}

/^%SED_BK_JUNI%}$/ && block_services == 1 {
	block_services = 0;
	next;
}

/^}$/ {
	block_system = 0;
}

ENDFILE {
	if ( pass ) print_err("services_forbidproto_notset.juniper-junos.gawk","services forbidden protocols are not set",0,"high","pass");
}

END {
}
