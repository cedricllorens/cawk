#
# @test_name : syslog_host_set.juniper-junos.gawk
# @supplier : juniper-junos
# @purpose : check if syslog host is configured inside system block
# @description : missing syslog host configuration means system logs are not being sent to a remote server, compromising log centralization and audit trail capabilities
# @actions : configure at least one syslog host with proper facility and severity settings to enable centralized logging (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AU-4 | Audit and Accountability | Ensure audit log storage capacity is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	in_system = 0;
	in_syslog = 0;
	syslog_host_found = 0;
}

/^system {/ && !/inactive/ {
	in_system = 1;
}

in_system && /^%SED_BK_JUNI%syslog {/ && !/inactive/ {
	in_syslog = 1;
}

in_syslog && /^%SED_BK_JUNI%%SED_BK_JUNI%host [^ ]+ {/ && !/inactive/ {
	print_err("syslog_host_set.juniper-junos.gawk",$0,FNR,"high","pass");
	syslog_host_found = 1;
}

/^%SED_BK_JUNI%}$/ && in_syslog {
	in_syslog = 0;
}

/^}$/ && in_system && !in_syslog {
	in_system = 0;
}

ENDFILE {
	if ( !syslog_host_found ) print_err("syslog_host_set.juniper-junos.gawk","syslog host is not configured inside system block",0,"high","error");
}

END {
}
