#
# @test_name : lineaux_exectimeout00_notset.cisco-xe
# @supplier : cisco-xe
# @purpose : check if a line aux has no <exec-timeout 0 0>
# @description : exec-timeout 0 0 disables session timeout and can leave an unattended session active indefinitely
# @actions : set a proper exec-timeout value on line aux and remove <exec-timeout 0 0> (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.4.2 | Ensure exec-timeout is set on auxiliary lines | Console and Line Access
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( exec == 1 ) {
		print_err("lineaux_exectimeout00_notset.cisco-xe.gawk",lineaux" : <exec-timeout 0 0> is set",linenoaux,"high","error");
		pass = 1;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block_aux = 0;
	pass = 0;
}

/^line aux .*$/ {
	if ( block_aux == 1 ) acl_summary();
	lineaux = $0;
	linenoaux = FNR;
	exec = 0;
        block_aux = 1;
	next;
}

/^ exec-timeout 0 0/ && block_aux == 1 {
	exec = 1;
	next;
}

( /^!$/ || ( /^line / && !/ aux / ) ) && block_aux == 1 {
	acl_summary();
	block_aux = 0;
}

ENDFILE {
	if ( !pass ) print_err("lineaux_exectimeout00_notset.cisco-xe.gawk","line aux <exec-timeout 0 0> is not set",0,"high","pass");
}

END {
}
