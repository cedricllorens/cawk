#
# @test_name : linevty_sshinput_set.cisco-xe.gawk
# @supplier : cisco-xe
# @purpose : check if a line vty has <transport input (none|ssh)>
# @description : vty without restricting transport input to ssh or none allows insecure protocols (telnet) for remote management
# @actions : set <transport input ssh> or <transport input none> on line vty (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.4.6 | Ensure SSH is configured on VTY lines | SSH Access
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function sshinput_summary() {
	if ( sshinput == 0 ) {
		print_err("linevty_sshinput_set.cisco-xe.gawk",linevty" : transport input (none|ssh) is missing",linenovty,"high","error");
		pass = 0;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block_vty = 0;
	pass = 1;
}

/^line vty .*$/ {
	if ( block_vty == 1 ) sshinput_summary();
	linevty = $0;
	linenovty = FNR;
	sshinput = 0;
        block_vty = 1;
	next;
}

/^ transport input (none|ssh)$/ && block_vty == 1 {
	sshinput = 1;
	next;
}

/^!$/ && block_vty == 1 {
	sshinput_summary();
	block_vty = 0;
}

ENDFILE {
	if ( pass ) print_err("linevty_sshinput_set.cisco-xe.gawk","line vty transport input (none|ssh) are set",0,"high","pass");
}

END {
}
