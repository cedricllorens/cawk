#
# @test_name : global_servicepassword_set.cisco-xe.gawk
# @supplier : cisco-xe
# @purpose : check if <service password-encryption> is set
# @description : service password encryption must be used to encrypt passwords in the configuration file
# @actions : set <service password-encryption> or remove it (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-13 | System and Communications Protection | Ensure cryptographic protection using approved algorithms is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^service password-encryption/ {
	print_err("global_servicepassword_set.cisco-xe.gawk",$0,FNR,"high","pass");
	pass = 0;
	nextfile;
}

ENDFILE {
	if ( pass ) print_err("global_servicepassword_set.cisco-xe.gawk","<service password-encryption> is not set",0,"high","error");
}

END {
}
