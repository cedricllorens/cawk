#
# @test_name : global_logging_set.cisco-xe
# @supplier : cisco-xe
# @purpose : check if <logging host> is set for centralized logging
# @description : logging can be used to track system events and potential security incidents
# @actions : set logging host (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 3.1.1 | Ensure syslog logging is enabled | Logging
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 1;
}

/^logging ([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+|(host|server) [0-9]+\.[0-9]+\.[0-9]+\.[0-9]+)/ {
    print_err("global_logging_set.cisco-xe.gawk",$0,FNR,"medium","pass");
    pass = 0;
    nextfile;
}

ENDFILE {
    if ( pass == 1 ) print_err("global_logging_set.cisco-xe.gawk","<logging host> is not configured",0,"medium","error");
}

END {
}
