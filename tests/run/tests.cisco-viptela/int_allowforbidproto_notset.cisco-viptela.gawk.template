#
# @test_name : int_allowforbidproto_notset.cisco-viptela.gawk
# @supplier : cisco-viptela
# @purpose : check if <allow-service forbidden protocols> are not set on tunnel interfaces
# @description : enabling forbidden protocols on tunnel interfaces expands the attack surface and could expose the device to security risks
# @actions : remove forbidden protocol services from tunnel interfaces (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SI-2 | System and Information Integrity | Ensure flaw remediation and patching is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_vpn = 0;
	block_interface = 0;
	block_tunnelinterface = 0;
}

/^vpn/ {
	block_vpn = 1;
	next;
}

/^ interface/ && block_vpn == 1 {
	block_interface = 1;
	block_tunnelinterface = 0;
	next;
}

/^  tunnel-interface/ && block_interface == 1 {
	block_tunnelinterface = 1;
	next;
}

/^   allow-service %SED_FORBIDPROTO_VIPTELA%/ && block_tunnelinterface == 1 {
	print_err("int_allowforbidproto_notset.cisco-viptela.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^  !$/ && block_tunnelinterface == 1 {
	block_tunnelinterface = 0;
	next;
}

/^ !$/ && block_interface == 1 {
	block_interface = 0;
	next;
}

/^!$/ && block_vpn == 1 {
	block_vpn = 0;
	next;
}

ENDFILE {
	if ( pass ) print_err("int_allowforbidproto_notset.cisco-viptela.gawk","interface allowforbidprotos are not set",0,"high","pass");
}

END {
}
