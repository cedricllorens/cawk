#
# @test_name : snmp_v1v2_notset.cisco-viptela.gawk
# @supplier : cisco-viptela
# @purpose : check if <snmp v1v2> is not set
# @description : snmp v1 and v2c use clear-text community strings and lack strong authentication and encryption
# @actions : disable snmp v1/v2c community strings and migrate to snmp v3 (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AC-3 | Access Control | Ensure access enforcement is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_snmp = 0;
}

/^snmp/ {
	block_snmp = 1;
	next;
}

/^ community / && block_snmp == 1 {
	print_err("snmp_v1v2_notset.cisco-viptela.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^!$/ && block_snmp == 1 {
	block_snmp = 0;
	next;
}

ENDFILE {
	if ( pass ) print_err("snmp_v1v2_notset.cisco-viptela.gawk","snmp v1v2 is not set",0,"high","pass");
}

END {
}
