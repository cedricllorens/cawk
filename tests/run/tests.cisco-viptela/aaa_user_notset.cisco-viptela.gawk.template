#
# @test_name : aaa_user_notset.cisco-viptela
# @supplier : cisco-viptela
# @purpose : check if <aaa users> are not set locally
# @description : local users can endanger the security of the system by allowing unauthorized access
# @actions : remove local users or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.1.3 | Ensure local users are minimized | Authentication, Authorization & Accounting
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
}

/^system/ {
	block_system = 1;
	next;
}

/^ aaa/ && block_system == 1 {
	block_aaa = 1;
	next;
}

/^  user / && !/%SED_AUTHUSER_VIPTELA%/ && block_aaa == 1 {
	print_err("aaa_user_notset.cisco-viptela.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^ !$/ && block_aaa == 1 {
	block_aaa = 0;
	next;
}

/^!$/ && block_system == 1 {
	block_system = 0;
	next;
}

ENDFILE {
	if ( pass ) print_err("aaa_user_notset.cisco-viptela.gawk","aaa users forbidden are not set",0,"high","pass");
}

END {
}
