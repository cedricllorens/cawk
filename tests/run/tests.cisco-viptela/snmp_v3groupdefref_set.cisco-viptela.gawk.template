#
# @test_name : snmp_v3groupdefref_set.cisco-viptela
# @supplier : cisco-viptela
# @purpose : check if <snmp v3 group> definitions are referenced and references are defined
# @description : snmp v3 groups defined but not referenced (or vice versa) indicate configuration inconsistencies
# @actions : ensure all snmp v3 group definitions are used and all group references have a matching group definition (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.5 | Ensure SNMPv3 group references | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	delete snmp_def;
	delete snmp_ref;
	block_snmp = 0;
}

/^snmp/ {
	block_snmp = 1;
}

# def ----

/^[ ]group [^ ]+/ && block_snmp == 1 {
	snmp_def[$2] = $0;
	next;
}

# ref ----

/^[ ][ ]group[ ]+[^ ]+/ && block_snmp == 1 {
	snmp_ref[$2] = $0;
	next;
}

/^!$/ && block_snmp == 1 {
	block_snmp = 0;
	next;
}

ENDFILE {

	# snmp def and not ref
	for (id in snmp_def) {
		if ( !(id in snmp_ref) ) {
			print_err("snmp_v3groupdefref_set.cisco-viptela.gawk",id" : def not ref :"snmp_def[id],0,"info","error");
			pass = 0;
		}
	}

	# snmp ref and not def
	for (id in snmp_ref) {
		if ( !(id in snmp_def) ) {
			print_err("snmp_v3groupdefref_set.cisco-viptela.gawk",id" : ref not def :"snmp_ref[id],0,"high","error");
			pass = 0;
		}
	}

	if ( pass ) print_err("snmp_v3groupdefref_set.cisco-viptela.gawk","all snmps defs are refs and the reverse",0,"high","pass");
}

END {
}
