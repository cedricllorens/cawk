#
# @test_name : snmp_v1v2rw_notset.cisco-viptela
# @supplier : cisco-viptela
# @purpose : check if <snmp v1v2 rw> is not set
# @description : snmp v1/v2c read-write community string allows unauthorized configuration changes to the device
# @actions : remove rw community strings and use read-only community or migrate to snmp v3 (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.2 | Ensure SNMPv3 with authentication | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_snmp = 0;
}

/^snmp/ {
	block_snmp = 1;
	next;
}

/^ community / && block_snmp == 1 {
	block_community = 1;
	next;
}

/^  authorization write/ && block_community  == 1 {
	print_err("snmp_v1v2rw_notset.cisco-viptela.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^ !$/ && block_community == 1 {
	block_community = 0;
	next;
}

/^!$/ && block_snmp == 1 {
	block_snmp = 0;
	next;
}

ENDFILE {
	if ( pass ) print_err("snmp_v1v2rw_notset.cisco-viptela.gawk","snmp v1v2 rw is not set",0,"high","pass");
}

END {
}
