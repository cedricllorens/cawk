#
# @test_name : global_defaultpolicy_set.iptables-fwcli.gawk
# @supplier : iptables-fwcli
# @purpose : check that <-P default policy> is set
# @description : missing default policy means traffic not matched by explicit rules may be allowed by default instead of denied
# @actions : set a default drop policy on all chains to enforce implicit deny (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.2 | Ensure default firewall policy is set | Firewall Policy
# @authors : wael elsingaby
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    input_found = 1;
    forward_found = 1;
    output_found = 1;
}

/^iptables -P INPUT/ { 
    print_err("global_defaultpolicy_set.iptables-fwcli.gawk","default policy for input found <<"$0">>",FNR,"medium","pass");
    input_found = 0;
    next;
}

 /iptables -P FORWARD/ { 
    print_err("global_defaultpolicy_set.iptables-fwcli.gawk","default policy for forward found <<"$0">>",FNR,"medium","pass");
    forward_found = 0;
    next;
}

/^iptables -P OUTPUT/ { 
    print_err("global_defaultpolicy_set.iptables-fwcli.gawk","default policy for output found <<"$0">>",FNR,"medium","pass");
    output_found = 0;
    next;
}

ENDFILE {
    
    if (input_found) {
        print_err("global_defaultpolicy_set.iptables-fwcli.gawk","default policy for input not found",FNR,"medium","error");
    }

    if (forward_found) {
        print_err("global_defaultpolicy_set.iptables-fwcli.gawk","default policy for forward not found",FNR,"medium","error");
    }
    
    if (output_found) {
        print_err("global_defaultpolicy_set.iptables-fwcli.gawk","default policy for output not found",FNR,"medium","error");
    }

}

END {
}
