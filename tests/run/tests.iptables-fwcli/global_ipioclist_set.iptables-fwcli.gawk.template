#
# @test_name : global_ipioclist_set.iptables-fwcli.gawk
# @supplier : iptables-fwcli
# @purpose : check that <ip_ioc_list> is set
# @description : missing ip ioc list means known malicious ip indicators of compromise are not blocked at the firewall level
# @actions : configure ip_ioc_list with current threat intelligence feeds to block known malicious addresses (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.1.1 | Ensure IOC lists are configured | Threat Prevention
# @authors : wael elsingaby
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# local functions ----
function processrule(rule,ioc) {
    for (ip in ioc) {
        if( rule ~ ("-s[ ]*" ip)) {
            ioc[ip] = 1;
        }
    }
}
# local functions ----

BEGIN {
}

BEGINFILE {
    ioc["10.0.0.0"] = 0;
    rule = "";
}

# vars def ----
/^\w+[ \t]*=[ \t]*/ {
    for (ip in ioc) {
        if( $0 ~ ip ) {
            ioc[ip] = 1;
        }
    }
    next;
}

# rule def ----
/^iptables -A (INPUT|FORWARD|OUTPUT) / && !/\\$/ {
    processrule($0,ioc);
    next;
}

# multi line rule ----
/^iptables -A (INPUT|FORWARD|OUTPUT) / && /\\$/ && rule == "" {
    rule = rule $0;
    next;
}

/\\$/ && rule != "" {
    rule = rule $0;
    next;
}

!/\\$/ && rule != "" {
    rule = rule $0;
    processrule($0,ioc);
    rule = "";
    next;
}
# multi line rule ----

ENDFILE {
    pass = 1;
    for (ip in ioc) {
        if (ioc[ip] == 0) {
            print_err("global_ipioclist_set.iptables-fwcli.gawk","ioc ip not found <<"ip">>",0,"info","warning");
            pass = 0;
        }
    }
    if (pass == 1) {
        print_err("global_ipioclist_set.iptables-fwcli.gawk","all ioc ip are found ",0,"info","pass");
    }
}

END {
}
