#
# @test_name : aaa_user_notset.nokia-sros.gawk
# @supplier : nokia-sros
# @purpose : check if <aaa forbidden users> are not set
# @description : presence of forbidden aaa users indicates unauthorized or default accounts that should be removed
# @actions : remove forbidden aaa users and enforce least-privilege account management (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : IA-2 | Identification and Authentication | Ensure unique identification and authentication of organizational users is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
	block_security = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}user/ && !/%SED_AUTHUSER_NOKIA%/ && block_security == 1 {
	print_err("aaa_user_notset.nokia-sros.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( pass ) print_err("aaa_user_notset.nokia-sros.gawk","aaa forbidden users are not set",0,"high","pass");
}

END {
}
