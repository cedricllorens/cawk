# file support/tests.sed for further information
#
# @test_name : snmp_v1v2_notset.nokia-sros.gawk
# @supplier : nokia-sros
# @purpose : check if <snmp v1v2> is not set
# @description : snmp v1 and v2c use cleartext community strings and lack authentication, making them insecure
# @actions : disable snmp v1 and v2c and migrate to snmp v3 with authentication and encryption (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AC-3 | Access Control | Ensure access enforcement is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
	block_security = 0;
	block_snmp = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}snmp$/ && block_security == 1 {
	block_snmp = 1;
	next;
}

/^%SED_BK_NOKIA%{4}community/ && block_snmp == 1 {
	print_err("snmp_v1v2_notset.nokia-sros.gawk",rm_blank_before($0),FNR,"high","error");
        pass = 0;
	nextfile;
}

/^%SED_BK_NOKIA%{3}exit$/ && block_snmp == 1 {
	block_snmp = 0;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( pass ) print_err("snmp_v1v2_notset.nokia-sros.gawk","snmp v1v2 is not set",0,"high","pass");
}

END {
}
