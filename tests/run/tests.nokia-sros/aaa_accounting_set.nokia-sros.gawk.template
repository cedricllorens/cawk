#
# @test_name : aaa_accounting_set.nokia-sros.gawk
# @supplier : nokia-sros
# @purpose : check if <aaa accounting> is set
# @description : missing aaa accounting means user actions are not logged for audit and forensic purposes
# @actions : configure aaa accounting to record user authentication and command activity (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.1.2 | Ensure AAA accounting is configured | Authentication, Authorization & Accounting
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
	block_system = 0;
	block_security = 0;
	block_aaa = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}%SED_AAASYSTEM_NOKIA%/ && block_security == 1 {
	block_aaa = 1;
	next;
}

/^%SED_BK_NOKIA%{4}accounting/ && block_aaa == 1 {
	print_err("aaa_accounting_set.nokia-sros.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 1;
	nextfile;
}

/^%SED_BK_NOKIA%{3}exit$/ && block_aaa == 1 {
	block_aaa = 0;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( ! pass ) print_err("aaa_accounting_set.nokia-sros.gawk","aaa accounting is not set",0,"high","error");
}

END {
}
