#
# @test_name : login_forbidproto_notset.nokia-sros
# @supplier : nokia-sros
# @purpose : check if login forbidden forbidprotos are not set
# @description : forbidden login protocols such as telnet or ftp expose management access to cleartext interception
# @actions : disable forbidden login protocols and restrict management access to ssh only (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.1 | Ensure unsafe protocols are disabled | Network Protocols
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
	block_login = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}login-control/ && block_system == 1 {
	block_login = 1;
	next;
}

/^%SED_BK_NOKIA%{3}%SED_FORBIDPROTO_NOKIA%/ && block_login == 1 {
	print_err("login_forbidproto_notset.nokia-sros.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_login == 1 {
	block_login = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( pass ) print_err("login_forbidproto_notset.nokia-sros.gawk","login forbidden forbidprotos are not set",0,"high","pass");
}

END {
}
