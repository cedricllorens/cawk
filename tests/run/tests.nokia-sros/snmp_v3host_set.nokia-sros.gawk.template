#
# @test_name : snmp_v3host_set.nokia-sros.gawk
# @supplier : nokia-sros
# @purpose : check if <snmp v3 host> is set
# @description : missing snmp v3 host configuration means trap notifications are not sent to a secure management destination
# @actions : configure snmp v3 host with appropriate notification targets (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.6 | Ensure SNMPv3 traps are configured | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
	block_system = 0;
	block_security = 0;
	block_snmp = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}snmpv3$/ && block_security == 1 {
	block_snmp = 1;
	next;
}

/^%SED_BK_NOKIA%{4}trap-server/ && block_snmp == 1 {
	print_err("snmp_v3host_set.nokia-sros.gawk",rm_blank_before($0),FNR,"high","pass");
    pass = 1;
	next;
}

/^%SED_BK_NOKIA%{3}exit$/ && block_snmp == 1 {
	block_snmp = 0;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( !pass ) print_err("snmp_v3host_set.nokia-sros.gawk","snmp v3 host is not set",0,"high","error");
}

END {
}
