#
# @test_name : snmp_v1v2forbidcommunity_notset.nokia-sros
# @supplier : nokia-sros
# @purpose : check if <snmp v1v2 forbidden communities> are not set
# @description : use of well-known or default snmp community strings such as public or private exposes the device to unauthorized access
# @actions : remove or replace forbidden snmp community strings with strong unique values (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.3 | Ensure SNMPv1/v2 communities are restricted | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
	block_security = 0;
	block_snmp = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}snmp$/ && block_security == 1 {
	block_snmp = 1;
	next;
}

/^%SED_BK_NOKIA%{4}community/ && /%SED_SNMP_FORBID_COMMUNITY%/ && block_snmp == 1 {
	print_err("snmp_v1v2forbidcommunity_notset.nokia-sros.gawk",rm_blank_before($0),FNR,"high","error");
        pass = 0;
	nextfile;
}

/^%SED_BK_NOKIA%{3}exit$/ && block_snmp == 1 {
	block_snmp = 0;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( pass ) print_err("snmp_v1v2forbidcommunity_notset.nokia-sros.gawk","snmp v1v2 forbidden communties are not set",0,"high","pass");
}

END {
}
