#
# @test_name : fw_defaultpermitmgnt_notset.nokia-sros
# @supplier : nokia-sros
# @purpose : check if <firewall management default permit> is not set
# @description : firewall management default permit allows all unmatched traffic to the management plane instead of denying it
# @actions : change the default management firewall policy from permit to deny (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.2 | Ensure default management policy is deny | Firewall Policy
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
	block_security = 0;
	block_mgnt = 0;
	block_filter = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}management-access-filter/ && block_security == 1 {
	block_mgnt = 1;
	next;
}

/^%SED_BK_NOKIA%{4}ip-filter/ && block_mgnt == 1 {
	block_filter = 1;
	next;
}

/^%SED_BK_NOKIA%{5}default-action permit/ && block_filter == 1 {
        print_err("fw_defaultpermitmgnt_notset.nokia-sros.gawk",rm_blank_before($0),0,"high","error");
	pass = 0;
	next;
}

/^%SED_BK_NOKIA%{4}exit$/ && block_filter == 1 {
	block_filter = 0;
	next;
}

/^%SED_BK_NOKIA%{3}exit$/ && block_mgnt == 1 {
	block_mgnt = 0;
	next;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
	next;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
	next;
}

ENDFILE {
        if ( pass ) print_err("fw_defaultpermitmgnt_notset.nokia-sros.gawk","ip-filter default permit is not set",0,"high","pass");
}

END {
}
