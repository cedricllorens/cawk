#
# @test_name : aaa_config_set.nokia-sros
# @supplier : nokia-sros
# @purpose : check if <aaa config> is set
# @description : missing aaa configuration means authentication, authorization, and accounting are not properly enforced
# @actions : configure aaa with proper authentication and authorization settings (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.1 | Ensure AAA is configured | System Administration
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
	block_system = 0;
	block_security = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}%SED_AAASYSTEM_NOKIA%/ && block_security == 1 {
	print_err("aaa_config_set.nokia-sros.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 1;
	nextfile;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( ! pass ) print_err("aaa_config_set.nokia-sros.gawk","aaa config is not set",0,"high","error");
}

END {
}
