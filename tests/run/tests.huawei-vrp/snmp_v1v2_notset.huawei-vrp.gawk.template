#
# @test_name : snmp_v1v2_notset.huawei-vrp
# @supplier : huawei-vrp
# @purpose : check if <snmp v1v2> is not set
# @description : snmp v1 and v2c use cleartext community strings and lack authentication, making them insecure
# @actions : disable snmp v1 and v2c and migrate to snmp v3 with authentication and encryption (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.1 | Ensure SNMPv3 is used | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1 ;
}

/^snmp-agent community/ {
	print_err("snmp_v1v2_notset.huawei-vrp.gawk",$0,FNR,"high","error");
	pass = 0;
}

ENDFILE {
	if ( pass ) print_err("snmp_v1v2_notset.huawei-vrp.gawk","snmp v1v2 is not set",0,"high","pass");
}

END {
}
