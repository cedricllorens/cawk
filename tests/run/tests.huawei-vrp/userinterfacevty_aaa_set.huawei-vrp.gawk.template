#
# @test_name : userinterfacevty_aaa_set.huawei-vrp.gawk
# @supplier : huawei-vrp
# @purpose : check if each user-interface vty has <authentication-mode aaa>
# @description : vty lines without aaa authentication-mode allow access without centralized authentication enforcement
# @actions : configure authentication-mode aaa on all user-interface vty lines (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.1.1 | Ensure AAA is configured on user interface | System Administration
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( aaa == 0 ) {
		print_err("userinterfacevty_aaa_set.huawei-vrp.gawk",userinterface" : authentication-mode aaa missing",userinterfacenovty,"high","error");
		pass = 0;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block_vty = 0;
	pass = 1;
}

/^user-interface vty .*$/ {
	if ( block_vty == 1 ) acl_summary();
	userinterface = $0;
	userinterfacenovty = FNR;
	aaa = 0;
        block_vty = 1;
	next;
}

/^ authentication-mode aaa/ && block_vty == 1 {
	aaa = 1;
	next;
}

/^#$/ && block_vty == 1 {
	acl_summary();
	block_vty = 0;
}

ENDFILE {
	if ( pass ) print_err("userinterfacevty_aaa_set.huawei-vrp.gawk","user-interface vty authentication-mode aaa are set",0,"high","pass");
}

END {
}
