#
# @test_name : snmp_v1v2forbidcommunity_notset.huawei-vrp
# @supplier : huawei-vrp
# @purpose : check if <snmp v1v2 forbidden communities> is not set
# @description : use of well-known or default snmp community strings such as public or private exposes the device to unauthorized access
# @actions : remove or replace forbidden snmp community strings with strong unique values (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.3 | Ensure SNMPv1/v2 communities are restricted | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1 ;
}

/^snmp-agent community/ && /%SED_SNMP_FORBID_COMMUNITY%/{
	print_err("snmp_v1v2forbidcommunity_notset.huawei-vrp.gawk",$0,FNR,"high","error");
	pass = 0;
}

ENDFILE {
	if ( pass ) print_err("snmp_v1v2forbidcommunity_notset.huawei-vrp.gawk","snmp v1v2 do not use forbidden communities",0,"high","pass");
}

END {
}
