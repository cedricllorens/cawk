#
# @test_name : snmpview_defref_set.huawei-vrp
# @supplier : huawei-vrp
# @purpose : check when a <snmp view> is def and not ref / check when a <snmp view> is ref and not def
# @description : snmp view defined but not referenced represents dead configuration; snmp view referenced but not defined causes access control errors
# @actions : align snmp view definitions and references to ensure all views are used and all references are valid (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.0.0 | Review and classify | General Security
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	delete snmp_def;
	delete snmp_ref;
}

# def ----

/^snmp-agent mib-view [^ ]+/ {
	snmp_def[$3] = $0;
	next;
}

# ref ----

/^snmp-agent community .* mib-view [^ ]+/ {
	for(i=1;i<=NF;i++) {
		if ( $i == "mib-view" ) {
			snmp_ref[$(i+1)] = $0;
			break;
		}
	}
	next;
}

ENDFILE {

	# snmp def not ref ----
	for (id in snmp_def) {
		if ( !(id in snmp_ref) ) {
			print_err("snmpview_defref_set.huawei-vrp.gawk",id" : def not ref :"snmp_def[id],0,"info","error");
			pass = 0;
		}
	}

	# snmp ref not def ----
	for (id in snmp_ref) {
		if ( !(id in snmp_def) ) {
			print_err("snmpview_defref_set.huawei-vrp.gawk",id" : ref not def :"snmp_ref[id],0,"high","error");
			pass = 0;
		}
	}

	if ( pass ) print_err("snmpview_defref_set.huawei-vrp.gawk","all snmps defs are refs and the reverse",0,"high","pass");
}

END {
}
