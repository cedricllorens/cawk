#%SED_GAWK_PATH%

# ------------------------------------------------------------
# cawk is subjet to a MIT open-source licence
# please refer to the MIT licence file for further information
#
# for %SED_VAR% change like GAWK_PATH, etc. please refer to
# file support/tests.sed for further information
#
# purpose : check that <ip acl number standard ...> have inconsistent/redundant rules
# author  : cedric llorens
# ------------------------------------------------------------

# rule format ----------------------------------
# 1  rule_name          : string
# 2  rule_description   : string
# 3  action             : permit/deny
# 4  ingress/outgress   : "none","in","out","all"
# 5  interface          : "none",string
# 6  family             : "all", inet, inet6
# 7  src@               : ip
# 8  src_net@           : cird/netmask		set "none","host","any",[0-9]+,[0-9]+.[0-9]+.[0-9]+.[0-9]+
# 9  port_src           : port_src			set 0 if empty
# 10 port_src_range     : port_src_range	set 0 if empty
# 11 dst@               : ip				set 0 if empty
# 12 dst_net@           : cird/netmask		set "none","host","any",[0-9]+,[0-9]+.[0-9]+.[0-9]+.[0-9]+
# 13 port_dst           : port_dst			set 0 if empty
# 14 port_dst_range     : port_dst_range	set 0 if empty
# 15 protocol           : protocol			set "none" if empty
# rule format ----------------------------------

@include %SED_INCLUDE_PATH%
@include %SED_INCLUDE_PATH_FWLIB%

BEGIN {
}

BEGINFILE {
	cawk_init_hypercube_rules();
	block_acl = 0;
	valid_acl = 0;
	acl = "";
	check = 0;
}

/^acl number [^ ]+$/ {
	check = 1;
	if ( acl != $3 && acl != "" ) {
		if ( cawk_hypercube_rules_assessment() ) {
			print_err("acl_configconsistency_set.huawei-vrp.gawk","acl number "acl" has no redundant/inconsistent rules",FNR,"info","pass");
		}
		cawk_init_hypercube_rules();
	}
	acl = $3;
	block_acl = 1;
	valid_acl = 0;
}

# --------

/^[ ]rule[ ][0-9]+ (permit|deny) .*$/ && block_acl == 1 {
	rule_desc = "rule_line_"FNR" <"$0">";

	# action ----
	local_action = $3;
	local_current = 3;
	local_current = local_current + 1;

	# protocol ----
	if ( $(local_current) ~ /[a-z0=9]+/ && $(local_current) != /(source|destination)/ ) {
		
		if (  $(local_current) == "ip" ) {
			local_protocol = "none";
		} else {
			local_protocol = $(local_current);
		}
		local_current = local_current + 1;

	} else {

		local_protocol = "none";

	}

	# source ----
	local_src = "any"
	local_src_net = "any"

	if ( $(local_current) == "source" ) {

		valid_acl = 1;

		local_src = $(local_current+1);
		if ( $(local_current+1) == "any") {
			local_src_net = "any";
			local_current = local_current + 2;
		} else if ( $(local_current+2) == "0" || $(local_current+2) !~/[0-9\.]+/ || $(local_current+2) == "" ) {
			local_src_net = "host";
			local_current = local_current + 3;
		} else {
			local_src_net = cawk_netMaskInv($(local_current+2))
			local_current = local_current + 3;
		}
	
	}

	# source-port ----
	local_src_port = 0
	local_src_port_range = 0

	if ( $(local_current) == "source-port" ) {

		valid_acl = 1;

		if ( $(local_current+1) == "range" ) {

			local_src_port = int($(local_current+2));
			local_src_port_range = $(local_current+3);
			local_current = local_current + 4;

		} else {

			local_src_port = $(local_current+1);
			local_src_port_range = 0;
			local_current = local_current + 2;

		}
	
	}

	# destination ----
	local_dst = "any"
	local_dst_net = "any"

	if ( $(local_current) == "destination" ) {

		valid_acl = 1;

		local_dst = $(local_current+1);
		if ( $(local_current+1) == "any") {
			local_dst_net = "any";
			local_current = local_current + 2;
		} else if ( $(local_current+2) == "0" || $(local_current+2) !~/[0-9\.]+/ || $(local_current+2) == "" ) {
			local_dst_net = "host";
			ocal_current = local_current + 3;
		} else {
			local_dst_net = cawk_netMaskInv($(local_current+2));
			ocal_current = local_current + 3;
		}
	
	}

	# destination-port ----
	local_dst_port = 0
	local_dst_port_range = 0

	if ( $(local_current) == "destination-port" ) {

		valid_acl = 1;

		if ( $(local_current+1) == "range" ) {

			local_dst_port = int($(local_current+2));
			local_dst_port_range = $(local_current+3);
			local_current = local_current + 4;

		} else {

			local_dst_port = $(local_current+1);
			local_dst_port_range = 0;
			local_current = local_current + 2;

		}
	
	}

	if ( valid_acl ) cawk_add_hypercube_rules("acl_configconsistency_set.huawei-vrp.gawk","acl number "acl" "rule_desc,local_action,"none","none","all",local_src,local_src_net,local_src_port,local_src_port_range,local_dst,local_dst_net,local_dst_port,local_dst_port_range,local_protocol)
	next;
}

/^#$/ && block_acl == 1 {

	if ( cawk_hypercube_rules_assessment() ) {
		print_err("acl_configconsistency_set.huawei-vrp.gawk","acl number "acl" has no redundant/inconsistent rules",FNR,"info","pass");
	}

	cawk_init_hypercube_rules();
	block_acl = 0;
	acl = "";
	valid_acl = 0;
}

ENDFILE { 
	if ( check == 0 ) print_err("acl_configconsistency_set.huawei-vrp.gawk","no <acl number [0-9]*> found",FNR,"info","pass");
}
