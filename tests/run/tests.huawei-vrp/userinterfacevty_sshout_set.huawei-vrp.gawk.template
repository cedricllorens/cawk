#
# @test_name : userinterfacevty_sshout_set.huawei-vrp
# @supplier : huawei-vrp
# @purpose : check if each user-interface vty has <ssh outbound>
# @description : vty lines without ssh outbound protocol restriction may allow insecure protocols for outbound connections
# @actions : configure protocol outbound ssh on all user-interface vty lines (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.4.1 | Ensure user access is properly controlled | Access Control
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( sshout == 0 ) {
		print_err("userinterfacevty_sshout_set.huawei-vrp.gawk",userinterface" : ssh outbound is not set",userinterfacenovty,"high","error");
		pass = 0;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block_vty = 0;
	pass = 1;
}

/^user-interface vty .*$/ {
	if ( block_vty == 1 ) acl_summary();
	userinterface = $0;
	userinterfacenovty = FNR;
	sshout = 0;
        block_vty = 1;
	next;
}

/^ protocol outbound ssh[ ]*$/ && block_vty == 1 {
	sshout = 1;
	next;
}

/^#$/ && block_vty == 1 {
	acl_summary();
	block_vty = 0;
}

ENDFILE {
	if ( pass ) print_err("userinterfacevty_sshout_set.huawei-vrp.gawk","user-interface vty ssh outbound are set",0,"high","pass");
}

END {
}
