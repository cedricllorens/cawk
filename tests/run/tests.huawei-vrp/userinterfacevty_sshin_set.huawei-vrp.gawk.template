#
# @test_name : userinterfacevty_sshin_set.huawei-vrp
# @supplier : huawei-vrp
# @purpose : check if each user-interface vty has <ssh inbound>
# @description : vty lines without ssh inbound protocol restriction may allow insecure protocols such as telnet for inbound connections
# @actions : configure protocol inbound ssh on all user-interface vty lines (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.4.1 | Ensure user access is properly controlled | Access Control
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( sshin == 0 ) {
		print_err("userinterfacevty_sshin_set.huawei-vrp.gawk",userinterface" : ssh inbound is not set",userinterfacenovty,"high","error");
		pass = 0;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block_vty = 0;
	pass = 1;
}

/^user-interface vty .*$/ {
	if ( block_vty == 1 ) acl_summary();
	userinterface = $0;
	userinterfacenovty = FNR;
	sshin = 0;
        block_vty = 1;
	next;
}

/^ protocol inbound ssh[ ]*$/ && block_vty == 1 {
	sshin = 1;
	next;
}

/^#$/ && block_vty == 1 {
	acl_summary();
	block_vty = 0;
}

ENDFILE {
	if ( pass ) print_err("userinterfacevty_sshin_set.huawei-vrp.gawk","user-interface vty ssh inbound are set",0,"high","pass");
}

END {
}
