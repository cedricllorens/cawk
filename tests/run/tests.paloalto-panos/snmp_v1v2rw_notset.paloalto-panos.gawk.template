#
# @test_name : snmp_v1v2rw_notset.paloalto-panos.gawk
# @supplier : paloalto-panos
# @purpose : check if <snmp v1v2 write> is not set
# @description : snmp v1v2 read-write community strings allow configuration changes via an insecure protocol
# @actions : disable snmp v1v2 read-write access and use snmp v3 with appropriate privileges (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.2 | Ensure SNMPv3 with authentication | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^%SED_BK_PALO%system/ {
	block_system = 1;
	next;
}

/^%SED_BK_PALO%{2}snmp/ && block_system == 1 {
	block_snmp = 1;
	next;
}

/^%SED_BK_PALO%{3}[ ]+access write/ && block_snmp == 1 {
	print_err("snmp_v1v2rw_notset.paloalto-panos.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	nextfile;
}


/^%SED_BK_PALO%{2}\}/ && block_snmp == 1 {
	block_snmp = 0;
	next;
}

/^%SED_BK_PALO%\}/ && block_system == 1 {
	block_system = 0;
	next;
}

ENDFILE {
	if ( pass ) {
		print_err("snmp_v1v2rw_notset.paloalto-panos.gawk","snmp v1v2 rw is not set",0,"high","pass");
	} 
}

END {
}
