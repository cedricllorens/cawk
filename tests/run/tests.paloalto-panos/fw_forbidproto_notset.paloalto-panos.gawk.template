#
# @test_name : fw_forbidproto_notset.paloalto-panos.gawk
# @supplier : paloalto-panos
# @purpose : check if firewall does not implement <forbidden protocols>
# @description : firewall rules permitting forbidden protocols allow insecure or dangerous services through the security policy
# @actions : remove or block rules that permit forbidden protocols (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.2 | Ensure forbidden protocols are blocked | Firewall Policy
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^security/ {
	block_firewall = 1;
	next;
}

/^%SED_BK_PALO%rules/ && block_firewall == 1 {
	block_rules = 1;
	next;
}

/^%SED_BK_PALO%{3}service %SED_FORBIDPROTO_PALO%/ && block_rules == 1 {
	print_err("fw_forbidproto_notset.paloalto-panos.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^%SED_BK_PALO%\}/ && block_rules == 1 {
	block_rules = 0;
	next;
}

/^\}/ && block_firewall == 1 {
	block_firewall = 0;
	next;
}

ENDFILE {
	if ( pass ) {
		print_err("fw_forbidproto_notset.paloalto-panos.gawk","firewall has no forbidden protocols",0,"high","pass");
	} 
}

END {
}
