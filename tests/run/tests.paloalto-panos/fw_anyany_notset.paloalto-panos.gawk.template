#
# @test_name : fw_anyany_notset.paloalto-panos.gawk
# @supplier : paloalto-panos
# @purpose : check if firewall does not implement <src=all dst=all service=any action=allow>
# @description : any-any allow rules permit all traffic between all sources and destinations, completely bypassing firewall controls
# @actions : replace any-any allow rules with specific rules matching only required traffic flows (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.1 | Ensure allow-all rules are restricted | Firewall Policy
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	src = 0;
	dst = 0;
	service = 0;
	pass = 1;
}

/^security/ {
	block_firewall = 1;
	next;
}

/^%SED_BK_PALO%rules/ && block_firewall == 1 {
	block_rules = 1;
	next;
}

/^%SED_BK_PALO%{2}[^ ]/ && !/^%SED_BK_PALO%{2}\}/ && block_rules == 1 {
	block_rule = 1;
	src = 0;
	dst = 0;
	service = 0;
	next;
}

/^%SED_BK_PALO%{3}source any/ && block_rules == 1 {
	src = 1;
	next;
}

/^%SED_BK_PALO%{3}destination any/ && block_rules == 1 {
	dst = 1;
	next;
}

/^%SED_BK_PALO%{3}service any/ && block_rules == 1 {
	service = 1;
	next;
}

/^%SED_BK_PALO%{3}action allow/ && block_rules == 1 {
	if ( src && dst && service ) {
		print_err("fw_anyany_notset.paloalto-panos.gawk","firewall has rule src=any dst=any service=any action=allow",FNR,"high","error");
		pass = 0;
	}
	next;
}

/^%SED_BK_PALO%\}/ && block_rules == 1 {
	block_rules = 0;
	next;
}

/^\}/ && block_firewall == 1 {
	block_firewall = 0;
	next;
}

ENDFILE {
	if ( pass ) {
		print_err("fw_anyany_notset.paloalto-panos.gawk","firewall has no rule src=any dst=any service=any action=allow",0,"high","pass");
	} 
}

END {
}
