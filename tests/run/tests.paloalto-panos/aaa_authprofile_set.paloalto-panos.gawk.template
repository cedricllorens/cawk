#
# @test_name : aaa_authprofile_set.paloalto-panos.gawk
# @supplier : paloalto-panos
# @purpose : check if <aaa authentication-profile> is set
# @description : missing aaa authentication profile means administrative access relies on local accounts only with no centralized authentication, logging or revocation
# @actions : configure an aaa authentication-profile bound to radius or tacacs+ servers for administrative access (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : IA-2 | Identification and Authentication | Ensure unique identification and authentication of organizational users
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
}

/^aaa/ {
	block_aaa = 1;
	next;
}

/^%SED_BK_PALO%{1}authentication-profile/ && block_aaa == 1 {
	print_err("aaa_authprofile_set.paloalto-panos.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 1;
	next;
}

/^\}/ && block_aaa == 1 {
	block_aaa = 0;
	next;
}

ENDFILE {
	if ( !pass ) print_err("aaa_authprofile_set.paloalto-panos.gawk","aaa authentication-profile is not set",0,"high","error");
}

END {
}
