#
# @test_name : global_sourcerouting_notset.fortinet-fortios.gawk
# @supplier : fortinet-fortios
# @purpose : check if <source-routing> is not set
# @description : ip source-route can be used to trigger attacks or can be used for unusual routing paths
# @actions : disable <source-routing> (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.1 | Ensure source routing is disabled | Network Protocols
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1 ;
	block_global = 0;
}

/^config system settings/ {
	block_global = 1;
	next;
}

/^%SED_BK_FORTI%set source-routing enable/ && block_global == 1 {
	print_err("global_sourcerouting_notset.fortinet-fortios.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;	
	next;
}

/^end$/ {
	block_global = 0;
}

ENDFILE {
	if ( pass ) print_err("global_sourcerouting_notset.fortinet-fortios.gawk","no mgnt interface is set",0,"high","pass");
}

END {
}
