#
# @test_name : fw_allall_notset.fortinet-fortios
# @supplier : fortinet-fortios
# @purpose : check if a <firewall rule> implements src=all dst=all service=all action=accept
# @description : a firewall rule accepting all sources, destinations and services creates a security bypass and exposes the device to attacks
# @actions : replace overly permissive rules with specific source, destination and service definitions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.1 | Ensure allow-all rules are restricted | Firewall Policy
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	src = 0;
	dst = 0;
	service = 0;
}

/^config firewall policy/ {
	block_firewall = 1;
	next;
}

/^%SED_BK_FORTI%edit / && block_firewall == 1 {
	block_edit = 1;
	src = 0;
	dst = 0;
	service = 0;
	next;
}

/^%SED_BK_FORTI%{2}set srcaddr "all"/ && block_edit == 1 {
	src = 1;
	next;
}

/^%SED_BK_FORTI%{2}set dstaddr "all"/ && block_edit == 1 {
	dst = 1;
	next;
}

/^%SED_BK_FORTI%{2}set service "ALL"/ && block_edit == 1 {
	service = 1;
	next;
}

/^%SED_BK_FORTI%{2}set action accept/ && block_edit == 1 {
	if ( src && dst && service ) {
		print_err("fw_allall_notset.fortinet-fortios.gawk","firewall has rule src=all dst=all service=all action=accept",FNR,"high","error");
		pass = 0;
	}
	next;
}

/^%SED_BK_FORTI%next$/ && block_edit == 1 {
	block_edit = 0;
	next;
}

/^end$/ && block_firewall == 1 {
	block_firewall = 0;
}

ENDFILE {
	if ( pass ) print_err("fw_allall_notset.fortinet-fortios.gawk","firewall has no rule src=all dst=all service=all action=accept",0,"high","pass");
}

END {
}
