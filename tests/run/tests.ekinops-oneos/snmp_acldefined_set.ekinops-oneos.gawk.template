#
# @test_name : snmp_acldefined_set.ekinops-oneos
# @supplier : ekinops-oneos
# @purpose : check if <snmp acl defined> is set
# @description : snmp without acl restriction may allow unauthorized snmp access from any host
# @actions : define and apply an ACL to restrict snmp access to authorized hosts only (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.1 | Ensure SNMP has access controls | SNMP
# @authors : julien lair
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    delete list_ACL_use;
    delete list_ACL_defined;
    pass = 1;
}

/^snmp set-[^ ]+-community .*[ ]?.*$/{
    if ( $4 == "" ) {
        print_err("snmp_acldefined_set.ekinops-oneos.gawk","<snmp acl defined> is defined without acl : "$0,FNR,"high","error");
        pass = 0;
        next;
    }
    list_ACL_use[$4] = 1;
    next;
   
}

/^ip access-list (extended|standard) .*$/{
    list_ACL_defined[$4] = 1;
    next;
}

ENDFILE {
    # check acls found ----
    for (acl in list_ACL_use) {
        if(!(acl in list_ACL_defined)){
            print_err("snmp_acldefined_set.ekinops-oneos.gawk","<snmp acl defined> acl " acl " is used but never declared",FNR,"high","error");
            pass = 0;
        }
    }

    if (pass == 1) print_err("snmp_acldefined_set.ekinops-oneos.gawk","<snmp acl defined> are properly declared",0,"high","pass");

}

END {
}
