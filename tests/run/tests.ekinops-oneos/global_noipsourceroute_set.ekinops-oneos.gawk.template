#
# @test_name : global_noipsourceroute_set.ekinops-oneos
# @supplier : ekinops-oneos
# @purpose : check if <no ip source-route> is set
# @description : ip source-route can be used to trigger attacks or can be used for unusual routing paths
# @actions : set <no ip source-route> (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.1 | Ensure IP source-route is disabled | Network Protocols
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 0;
}

/^no ip source-route$/{
    print_err("global_noipsourceroute_set.ekinops-oneos.gawk","<no ip source-route> is set : "$0,FNR,"high","pass");
    pass = 1;
    nextfile;
}

ENDFILE {
    if (pass == 0) print_err("global_noipsourceroute_set.ekinops-oneos.gawk","<no ip source-route> is not set",0,"high","error");
}

END {
}
