#
# @test_name : login_logenable_set.ekinops-oneos
# @supplier : ekinops-oneos
# @purpose : check if <login log enable> is set
# @description : login logging can be used to track authentication events and potential security incidents
# @actions : set <login log enable> (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 3.1.1 | Ensure login attempts are logged | Logging
# @authors : julien lair
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 0;
}

/^login on-(failure|success).*$/{
    if($3 == "log") {
        print_err("login_logenable_set.ekinops-oneos.gawk","<login log enable> found : "$0,FNR,"high","pass");
        pass = 1;
    } else {
        print_err("login_logenable_set.ekinops-oneos.gawk","<login log enable> need to add log in : "$0,FNR,"high","error");
        pass = 1;
    }
    next;
}

ENDFILE {
    if ( pass == 0) print_err("login_logenable_set.ekinops-oneos.gawk","<login log enable> not configured",FNR,"high","pass");
}

END {
}
