#
# @test_name : global_noipicmpredirect_set.ekinops-oneos
# @supplier : ekinops-oneos
# @purpose : check if <no ip icmp redirect> is set
# @description : ip icmp redirect may trigger attacks
# @actions : set <no ip icmp redirect> (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.1 | Ensure unsafe IP options are disabled | Network Protocols
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 0;
}

/^no ip icmp redirect$/{
    print_err("global_noipicmpredirect_set.ekinops-oneos.gawk","<no ip icmp redirect> is set : "$0,FNR,"high","pass");
    pass = 1;
    nextfile;
}

ENDFILE {
    if (pass == 0) print_err("global_noipicmpredirect_set.ekinops-oneos.gawk","<no ip icmp redirect> is not set",0,"high","error");
}

END {
}
