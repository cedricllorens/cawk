#
# @test_name : ntp_accessgroup_set.cisco-xr.gawk
# @supplier : cisco-xr
# @purpose : check if <ntp access-group> is set
# @description : ntp without access-group restriction can allow unauthorized ntp synchronization requests to or from any host
# @actions : set <ntp access-group> with appropriate ACL to restrict ntp access (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AU-8(1) | Audit and Accountability | Ensure time synchronization with authoritative source is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_ntp = 0;
}

/^(s)?ntp$/ {
	block_ntp = 1;
	next;
}

/ access-group / && block_ntp == 1 {
	print_err("ntp_accessgroup_set.cisco-xr.gawk",$0,FNR,"high","pass");
	pass = 0;
	nextfile;
}

/^!$/ && block_ntp == 1 {
	block_ntp = 0;
	next;
}

ENDFILE {
	if ( pass ) print_err("ntp_accessgroup_set.cisco-xr.gawk","<ntp server> is not set",0,"high","error");
}

END {
}
