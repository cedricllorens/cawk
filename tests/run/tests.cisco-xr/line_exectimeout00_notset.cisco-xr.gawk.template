#
# @test_name : line_exectimeout00_notset.cisco-xr.gawk
# @supplier : cisco-xr
# @purpose : check if a line vty has no <exec-timeout 0 0>
# @description : exec-timeout 0 0 disables session timeout and can leave an unattended vty session active indefinitely
# @actions : set a proper exec-timeout value on line vty and remove <exec-timeout 0 0> (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SI-2 | System and Information Integrity | Ensure flaw remediation and patching is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( exec == 1 ) {
		print_err("line_exectimeout00_notset.cisco-xr.gawk",line" : <exec-timeout 0 0> is set",linenovty,"high","error");
		pass = 1;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block = 0;
	pass = 0;
}

/^line .*$/ && !/console/ {
	if ( block == 1 ) acl_summary();
	line = $0;
	linenovty = FNR;
	exec = 0;
        block = 1;
	next;
}

/^ exec-timeout 0 0/ && block == 1 {
	exec = 1;
	next;
}

/^!$/ && block == 1 {
	acl_summary();
	block = 0;
}

ENDFILE {
	if ( !pass ) print_err("line_exectimeout00_notset.cisco-xr.gawk","line vty <exec-timeout 0 0> is not set",0,"high","pass");
}

END {
}
