#
# @test_name : aaa_config_set.cisco-xr.gawk
# @supplier : cisco-xr
# @purpose : check if <aaa config> is set
# @description : partial aaa configuration setup could endanger device security (authentication, authorization, and accounting must be configured)
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : IA-2 | Identification and Authentication | Ensure unique identification and authentication of organizational users is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass_ser = 1;
	pass_auth = 1;
	pass_autho = 1;
	pass_acc = 1;
}

/^(tacacs|radius)(-| )server / {
	print_err("aaa_config_set.cisco-xr.gawk",$0,FNR,"high","pass");
	pass_ser = 0;
	next;
}

/^aaa authentication / {
	pass_auth = 0;
	print_err("aaa_config_set.cisco-xr.gawk",$0,FNR,"high","pass");
	next;
}

/^aaa authorization / {
	pass_autho = 0;
	print_err("aaa_config_set.cisco-xr.gawk",$0,FNR,"high","pass");
	next;
}

/^aaa accounting / {
	pass_acc = 0;
	print_err("aaa_config_set.cisco-xr.gawk",$0,FNR,"high","pass");
}

ENDFILE {
	if ( pass_serv ) print_err("aaa_config_set.cisco-xr.gawk","<(tacacs|radius) server> is not set",0,"high","error");
	if ( pass_auth ) print_err("aaa_config_set.cisco-xr.gawk","<aaa authentication> is not set",0,"high","error");
	if ( pass_autho ) print_err("aaa_config_set.cisco-xr.gawk","<aaa authorization> is not set",0,"high","error");
	if ( pass_acc ) print_err("aaa_config_set.cisco-xr.gawk","<aaa accounting> is not set",0,"high","error");
}

END {
}
