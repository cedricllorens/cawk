#
# @test_name : acl_defref_set.cisco-xr
# @supplier : cisco-xr
# @purpose : check if <acl> definitions are referenced
# @description : unreferenced ACLs can lead to security vulnerabilities
# @actions : remove unreferenced ACLs or reference them (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.1 | Ensure ACL definitions are referenced | Access Control
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	delete acl_def;
	delete acl_ref;
}

# def ----

/^access-list [^ ]+/ {
	acl_def[$2] = $0;
	next;
}

/^(ip|ipv[46]|ethernet-service) access-list (standard|extended )?[^ ]+$/ {
	acl_def[$NF] = $0;
	next;
}

# ref ----

/^[ ]+(ip|ipv[46]|ethernet-service) access-group [^ ]+/ {
	acl_ref[$3] = $0;
	next;
}

/^[ ]+access-group ipv4 peer [^ ]+$/ {
	acl_ref[$NF] = $0;
	next;
}

/^snmp-server community .* (IPv4|IPv6) [^ ]+$/ || /^snmp-server group .* (IPv4|IPv6) [^ ]+$/{
	acl_ref[$NF] = $0;
	next;
}

/^snmp-server group .* access [^ ]+$/ {
	acl_ref[$NF] = $0;
	next;
}

/^[ ]*for [^ ]+$/ {
	acl_ref[$NF] = $0;
	next;
}

/^[ ]*allocate for [^ ]+$/ {
	acl_ref[$NF] = $0;
	next;
}

/^ access-class (ingress|outgress) [^ ]+/ && $4 != "prefix-list" {
	acl_ref[$3] = $0;
	next;
}

/^[ ]*match access-group (ip|ipv[46]|ethernet-service) [^ ]+/ {
	acl_ref[$4] = $0;
	next;
}

/^[ ]*ssm range [^ ]+$/ && !/[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/ {
	acl_ref[$3] = $0;
	next;
}

ENDFILE {

	# acl def and not ref
	for (id in acl_def) {
		if ( !(id in acl_ref) ) {
			print_err("acl_defref_set.cisco-xr.gawk",id" : def not ref :"acl_def[id],0,"info","error");
			pass = 0;
		}
	}

	# acl ref and not def
	for (id in acl_ref) {
		if ( !(id in acl_def) ) {
			print_err("acl_defref_set.cisco-xr.gawk",id" : ref not def :"acl_ref[id],0,"high","error");
			pass = 0;
		}
	}

	if ( pass ) print_err("acl_defref_set.cisco-xr.gawk","all acls defs are refs and the reverse",0,"high","pass");
}

END {
}
