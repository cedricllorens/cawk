#
# @test_name : routing_defref_set.cisco-cedge
# @supplier : cisco-cedge
# @purpose : check if <routing> definitions are referenced and references are defined
# @description : route-maps or prefix-lists defined but not referenced (or vice versa) indicate dead configuration and potential routing inconsistencies
# @actions : remove unused route-maps and prefix-lists or fix missing references (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 4.1.1 | Ensure routing protocols are secured | Routing
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	delete routing_def;
	delete routing_ref;
}

# def ----

/^route-map [^ ]+/ {
	routing_def[$2] = $0;
	next;
}

/^ip(v4|v6)? prefix(-list)? [^ ]+/ {
	routing_def[$3] = $0;
	next;
}

# ref ----

/^.+ (advertise-map|suppress-map|inject-map|exit-map|import-map|export-map|table-map|route-map) .*/ && !/^route-map / && !/^[ ]*(#|remark[ ]|description[ ])/ {
	for(i=1;i<=NF;i++) {
		if ( $i == "route-map" || $i == "advertise-map" || $i == "suppress-map" || $i == "inject-map" || $i == "exit-map" || $i == "import-map" || $i == "export-map" || $i == "table-map") {
			routing_ref[$(i+1)] = $0;
			break;
		}
	}
	next;
}

/^.+ prefix(-list)? .*/ && !/^ip(v4|v6)? prefix(-list)?/ && !/^[ ]*(#|remark[ ]|description[ ])/ {
	for(i=1;i<=NF;i++) {
		if ( $i == "prefix-list" ) {
			if ( $(i+1) != "ip" && $(i+1) != "ipv4" && $(i+1) != "ipv6" ) {
				routing_ref[$(i+1)] = $0;
			} else {
				routing_ref[$(i+2)] = $0;
			}
			break;
		}
	}
	next;
}

/^ match ip address prefix-list [^ ]+/ && !/^[ ]*(#|remark[ ]|description[ ])/ {
	routing_ref[$5] = $0;
	next;
}

ENDFILE {

	# routing def and not ref
	for (id in routing_def) {
		if ( !(id in routing_ref) ) {
			print_err("routing_defref_set.cisco-cedge.gawk",id" : def not ref :"routing_def[id],0,"info","error");
			pass = 0;
		}
	}

	# routing ref and not def
	for (id in routing_ref) {
		if ( !(id in routing_def) ) {
			print_err("routing_defref_set.cisco-cedge.gawk",id" : ref not def :"routing_ref[id],0,"high","error");
			pass = 0;
		}
	}

	if ( pass ) print_err("routing_defref_set.cisco-cedge.gawk","all routings defs are refs and the reverse",0,"high","pass");
}

END {
}
