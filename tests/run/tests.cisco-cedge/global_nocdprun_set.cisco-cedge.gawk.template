# file support/tests.sed for further information
#
# @test_name : global_nocdprun_set.cisco-cedge.gawk
# @supplier : cisco-cedge
# @purpose : check if <no cdp run> is set and <cdp run> is not set
# @description : cdp can be used to gain unauthorized access to the device or reveal sensitive information
# @actions : set <no cdp run> or remove <cdp run> (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^no (ip )?cdp run/ {
	print_err("global_nocdprun_set.cisco-cedge.gawk",$0,FNR,"high","pass");
	pass = 0;
	next;
}

/^(ip )?cdp run/ {
	print_err("global_nocdprun_set.cisco-cedge.gawk","<cdp run> is set",0,"high","error");
	pass = 2;
	next;
}

ENDFILE {
	if ( pass == 1 ) print_err("global_nocdprun_set.cisco-cedge.gawk","<no cdp run> is set by default",0,"high","pass");
}

END {
}
