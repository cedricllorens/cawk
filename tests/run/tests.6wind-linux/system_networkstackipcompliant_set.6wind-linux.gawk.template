# file support/tests.sed for further information
#
# @test_name : system_networkstackipcompliant_set.6wind-linux
# @supplier : 6wind-linux
# @purpose : check if <system><network-stack><ipv4/ipv6> block is compliant (accept-redirects, accept-source-route, accept-router-advert, arp-proxy)
# @description : non-compliant IP network stack settings could expose the device to IP-based attacks such as ICMP redirects, source routing abuse, rogue router advertisements, or ARP proxy spoofing
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.3.2 | Ensure IP stack is properly configured | Network Hardening
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 1;
    block = 0;
}

/^system$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%network-stack$/ && block {
    block = 2;
    next;
}

/^%SED_BK_WIND%{2}(ipv4|ipv6)$/ && block == 2 {
    next;
}

/^%SED_BK_WIND%{3}accept-redirects[ ]/ && block == 2 {
    if (match($0, /true$/)) {
        print_err("system_networkstackipcompliant_set.6wind-linux.gawk", "<system><network-stackip><ipv4/ipv6> block not compliant / accept-redirects not set to false", FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{3}accept-source-route[ ]/ && block == 2 {
    if (match($0, /true$/)) {
        print_err("system_networkstackipcompliant_set.6wind-linux.gawk", "<system><network-stackip><ipv4/ipv6> block not compliant / accept-source-route not set to false", FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{3}accept-router-advert[ ]/ && block == 2 {
    if (match($0, /true$/)) {
        print_err("system_networkstackipcompliant_set.6wind-linux.gawk", "<system><network-stackip><ipv4/ipv6> block not compliant / accept-router-advert not set to false", FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{3}arp-proxy[ ]/ && block == 2 {
    if (match($0, /true$/)) {
        print_err("system_networkstackipcompliant_set.6wind-linux.gawk", "<system><network-stackip><ipv4/ipv6> block not compliant / arp-proxy not set to false", FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%\.\.|exit|[^ ])/ {
    block = 1;
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
    next;
}

ENDFILE {
    if (pass) {
        print_err("system_networkstackipcompliant_set.6wind-linux.gawk", "<system><network-stackip><ipv4/ipv6> block is compliant", FNR, "high", "pass");
    }
}

END {
}

