# file support/tests.sed for further information
#
# @test_name : global_snmpcustforbidcommunity_notset.6wind-linux.gawk
# @supplier : 6wind-linux
# @purpose : check if <vrf main><snmp> custom block is compliant (trusted communities, authorization, destination)
# @description : non-compliant SNMP custom community configuration (forbidden communities, read-write access, or invalid destination) could expose the device to unauthorized access or information disclosure
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AC-3 | Access Control | Ensure access enforcement is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    cust = "";
    pass = 1;
    block = 0;
}

/^vrf main$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%snmp$/ && block {
    block = 2;
    next;
}

/^%SED_BK_WIND%{2}community[ ].*$/ && block == 2 {
    next;
}

/^%SED_BK_WIND%{3}(identifier|traps).*$/ && block == 2 {
    cust = $0;
    next;
}

/^%SED_BK_WIND%{3}destination/ && block == 2 {
    if (match($0, /community (public|private)$/) || !match($0, /[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/) || !match($0, /port 162[ ]/)) {
        print_err("global_snmpcustforbidcommunity_notset.6wind-linux.gawk", "<vrf main><snmp> cust block not compliant / destination not compliant : "rm_blank_before($0), FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{4}authorization.*$/ && block == 2 {
    if (!match($0, /read-only$/)) {
        print_err("global_snmpcustforbidcommunity_notset.6wind-linux.gawk", "<vrf main><snmp> cust block not compliant / forbidden authorizationi : "rm_blank_before($0), FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{4}destination.*$/ && block == 2 {
    if (!match($0, /[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/)) {
        print_err("global_snmpcustforbidcommunity_notset.6wind-linux.gawk", "<vrf main><snmp> cust block not compliant / forbidden ip address : "rm_blank_before($0), FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{4}community[ ].*$/ && block == 2 {
    if (match($0, /(private|public)$/)) {
        print_err("global_snmpcustforbidcommunity_notset.6wind-linux.gawk", "<vrf main><snmp> cust block not compliant / forbidden snmp community : "rm_blank_before($0), FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%(\.\.|exit|[^ ])/ {
    block = 1;
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
    next;
}

ENDFILE {
    if (pass) {
        print_err("global_snmpcustforbidcommunity_notset.6wind-linux.gawk", "<vrf main><snmp> cust block is compliant", FNR, "high", "pass");
    }
}

END {
}
