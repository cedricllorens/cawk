# file support/tests.sed for further information
#
# @test_name : global_ntpcompliant_set.6wind-linux
# @supplier : 6wind-linux
# @purpose : check if <vrf main><ntp> block is compliant (time-sources, enabled true)
# @description : non-compliant NTP configuration could affect time synchronization and undermine log integrity and audit trail reliability
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 3.1 | Ensure NTP is properly configured | Logging and Timestamping
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    enable = 1;
    pass = 1;
    block = 0;
}

/^vrf main$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%ntp$/ && block {
    block = 2;
    next;
}

/^%SED_BK_WIND%{2}time-sources$/ && block == 2 {
    next;
}

/^%SED_BK_WIND%{2}enabled true$/ && block == 2 {
    enable = 0;
    next;
}

/^%SED_BK_WIND%{3}server/ && block == 2 {
    if (!match($0, /server [0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/)) {
        print_err("global_ntpcompliant_set.6wind-linux.gawk", "<vrf main><ntp> block not compliant / bad address : "rm_blank_before($0), FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%(\.\.|exit|[^ ])/ {
    block = 1;
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
    next;
}

ENDFILE {
    if (enable) {
        print_err("global_ntpcompliant_set.6wind-linux.gawk", "<vrf main><ntp> block not compliant / enabled true is not set", FNR, "high", "error");
        pass = 0;
    }
    if (pass) {
        print_err("global_ntpcompliant_set.6wind-linux.gawk", "<vrf main><ntp> block is compliant", FNR, "high", "pass");
    }
}

END {
}
