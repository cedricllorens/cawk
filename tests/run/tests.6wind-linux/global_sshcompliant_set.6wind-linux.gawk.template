# file support/tests.sed for further information
#
# @test_name : global_sshcompliant_set.6wind-linux
# @supplier : 6wind-linux
# @purpose : check if <vrf main><ssh-server> block is compliant (port, permit-root-login, enabled true)
# @description : non-compliant SSH server configuration (missing port, root login allowed, or service disabled) could expose the device to unauthorized remote access
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.5.1 | Ensure SSH is securely configured | SSH
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    enable = 1;
    port_05 = 1;
    permit_05 = 1;
    pass = 1;
    block = 0;
}

/^vrf main$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%ssh-server$/ && block {
    block = 2;
    next;
}

/^%SED_BK_WIND%{2}port 22$/ && block == 2 {
    port_05 = 0;
    next;
}

/^%SED_BK_WIND%{2}permit-root-login no$/ && block == 2 {
    permit_05 = 0;
    next;
}

/^%SED_BK_WIND%{2}enabled true$/ && block == 2 {
    enable = 0;
    next;
}

/^%SED_BK_WIND%(\.\.|exit|[^ ])/ {
    block = 1;
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
    next;
}

ENDFILE {
    if (enable) {
        print_err("global_sshcompliant_set.6wind-linux.gawk", "<vrf main><ssh-server> block not compliant / <enabled true> is not set", FNR, "high", "error");
        pass = 0;
    }
    if (port_05) {
        print_err("global_sshcompliant_set.6wind-linux.gawk", "<vrf main><ssh-server> block not compliant / <port 22> is not set", FNR, "high", "error");
        pass = 0;
    }
    if (permit_05) {
        print_err("global_sshcompliant_set.6wind-linux.gawk", "<vrf main><ssh-server> block not compliant / <permit-root-login no> is not set", FNR, "high", "error");
        pass = 0;
    }
    if (pass) {
        print_err("global_sshcompliant_set.6wind-linux.gawk", "<vrf main><ssh-server> block is compliant", FNR, "high", "pass");
    }
}

END {
}
