#
# @test_name : global_forbidservices_notset.6wind-linux.gawk
# @supplier : 6wind-linux
# @purpose : check if <vrf main> block only contains trusted services
# @description : unauthorized or unexpected services running in vrf main expand the attack surface and could expose the device to security risks
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.1 | Ensure unnecessary services are disabled | Services
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 1;
    block = 0;
}

/^vrf main$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%[^ ].*$/ && block {
    if (!match($0, /^[ ]{4}(interface|netconf-server|ntp|snmp|ssh-server|logging|\.\.)$/)) {
        print_err("global_forbidservices_notset.6wind-linux.gawk", "<vrf main> block is not compliant / forbidden service : "rm_blank_before($0), FNR, "high","error");
        pass = 0;
    }
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
}

ENDFILE {
    if (pass) {
        print_err("global_forbidservices_notset.6wind-linux.gawk", "<vrf main> block is compliant", FNR, "high", "pass");
    }
}

END {
}
