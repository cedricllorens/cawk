# file support/tests.sed for further information
#
# @test_name : global_oldercryptoalg_notset.6wind-linux
# @supplier : 6wind-linux
# @purpose : check if <older crypto algorithm> is not set
# @description : usage of deprecated or weak cryptographic algorithms weakens device security and could be exploited by an attacker
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.7.1 | Ensure strong encryption algorithms are used | Cryptography
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

tolower($0) ~ /%SED_OLD_CRYPTO%/ {
	print_err("global_oldercryptoalg_notset.6wind-linux.gawk",$0,FNR,"high","error");
        pass = 0;
	nextfile;
}

ENDFILE {
        if ( pass ) print_err("global_oldercryptoalg_notset.6wind-linux.gawk","<older crypto algorithm> is not set",0,"high","pass");
}

END {
}
