# file support/tests.sed for further information
#
# @test_name : system_networkstackicmpcompliant_set.6wind-linux
# @supplier : 6wind-linux
# @purpose : check if <system><network-stack><icmp> block is compliant (rate-limit-icmp, rate-mask-icmp destination-unreachable, ignore-icmp-echo-broadcast)
# @description : non-compliant ICMP network stack settings could expose the device to ICMP flood or amplification attacks and information leakage via broadcast echo
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.3.1 | Ensure ICMP is properly configured | Network Hardening
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 1;
    block = 0;
    rate_09 = 0;
    ratemask_09 = 0;
}

/^system$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%network-stack$/ && block {
    block = 2;
    next;
}

/^%SED_BK_WIND%{2}icmp$/ && block == 2 {
    block = 3;
    next;
}

/^%SED_BK_WIND%{3}ignore-icmp-echo-broadcast[ ]/ && block == 3 {
    if (match($0, /true$/)) {
        print_err("system_networkstackicmpcompliant_set.6wind-linux.gawk", "<system><network-stack><icmp> block not compliant / ignore-icmp-echo-broadcast not set to false", FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{3}rate-limit-icmp/ && block == 3 {
    rate_09 = 1;
    next;
}

/^%SED_BK_WIND%{3}rate-mask-icmp destination-unreachable/ && block == 3 {
    ratemask_09 = 1;
    next;
}

/^%SED_BK_WIND%{2}(\.\.|exit|[^ ])/ {
    block = 2;
    next;
}

/^%SED_BK_WIND%(\.\.|exit|[^ ])/ {
    block = 1;
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
    next;
}

ENDFILE {
    if (!rate_09) {
        print_err("system_networkstackicmpcompliant_set.6wind-linux.gawk", "<system><network-stack><icmp> block not compliant / rate-limit-icmp not set", FNR, "high", "error");
        pass = 0;
    }
    if (!ratemask_09) {
        print_err("system_networkstackicmpcompliant_set.6wind-linux.gawk", "<system><network-stack><icmp> block not compliant / rate-mask-icmp destination-unreachable not set", FNR, "high", "error");
        pass = 0;
    }
    if (pass) {
        print_err("system_networkstackicmpcompliant_set.6wind-linux.gawk", "<system><network-stack><icmp> block is compliant", FNR, "high", "pass");
    }
}

END {
}

