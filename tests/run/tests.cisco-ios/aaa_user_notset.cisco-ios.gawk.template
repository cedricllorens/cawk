#
# @test_name : aaa_user_notset.cisco-ios.gawk
# @supplier : cisco-ios
# @purpose : check if <aaa users> are not set locally
# @description : local users can endanger the security of the system by allowing unauthorized access
# @actions : remove local users or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : to be defined
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^username / && !/^username %SED_AUTHUSER_CISCO%/ {
	print_err("aaa_user_notset.cisco-ios.gawk",$0,FNR,"high","error");
	pass = 0;
	next;
}

ENDFILE {
	if ( pass ) print_err("aaa_user_notset.cisco-ios.gawk","aaa forbidden users are not set",0,"high","pass");
}

END {
}
