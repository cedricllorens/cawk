#
# @test_name : ntp_accessgroup_set.cisco-ios
# @supplier : cisco-ios
# @purpose : check if <ntp access-group> is set
# @description : ntp without access-group restriction can allow unauthorized ntp synchronization requests to or from any host
# @actions : set <ntp access-group> with appropriate ACL to restrict ntp access (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 3.2.2 | Ensure NTP access is restricted | Logging and Timestamping
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^(s)?ntp access-group [^ ]+/ {
	print_err("ntp_accessgroup_set.cisco-ios.gawk",$0,FNR,"high","pass");
	pass = 0;
	nextfile;
}

ENDFILE {
	if ( pass ) print_err("ntp_accessgroup_set.cisco-ios.gawk","<ntp access-group> is not set",0,"high","error");
}

END {
}
