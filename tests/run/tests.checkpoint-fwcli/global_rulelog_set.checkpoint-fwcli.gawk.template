# @test_name : global_rulelog_set.checkpoint-fwcli
# @supplier : checkpoint-fwcli
# @purpose : check that <rule log> is set globally
# @description : rules without logging prevent detection of security incidents and make forensic analysis impossible
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 3.1.1 | Ensure firewall rules are logged | Logging
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# local functions ----
function processrule(rule) {

     if (rule ~ / track "?Log"?/) {
        print_err("global_rulelog_set.checkpoint-fwcli.gawk", "rule with logging <<"rule">>", FNR, "medium", "pass");
        pass = 0;
    }

}
# local functions ----

BEGIN {
}

BEGINFILE {
    rule = "";
    pass = 1;
}

# std line ----
/^(add )?(access-|nat-)?rule / && !/\\$/{
  processrule($0);
  next;
}
# std line ----

# multi line rule ----
/^(add )?(access-|nat-)?rule / && /\\$/ && rule == "" {
    rule = rule $0;
    next;
}

/\\$/ && rule != "" {
    rule = rule $0;
    next;
}

!/\\$/ && rule != "" {
    rule = rule $0;
    processrule(rule);
    rule = "";
    next;
}
# multi line rule ----

ENDFILE {
    if ( pass )  {
	    print_err("global_rulelog_set.checkpoint-fwcli.gawk","no rule with log is set",FNR,"medium","error");
    } 
}

END {
}
