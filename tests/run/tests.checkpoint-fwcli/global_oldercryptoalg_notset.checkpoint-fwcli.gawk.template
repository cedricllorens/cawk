#
# @test_name : global_oldercryptoalg_notset.checkpoint-fwcli
# @supplier : checkpoint-fwcli
# @purpose : check if <older crypto algorithm> is not set
# @description : older or deprecated cryptographic algorithms expose encrypted communications to known attacks and compromise data confidentiality
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.7.1 | Ensure strong encryption algorithms are used | Cryptography
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

tolower($0) ~ /%SED_OLD_CRYPTO%/ {
	print_err("global_oldercryptoalg_notset.checkpoint-fwcli.gawk",$0,FNR,"high","error");
        pass = 0;
	nextfile;
}

ENDFILE {
        if ( pass ) print_err("global_oldercryptoalg_notset.checkpoint-fwcli.gawk","<older crypto algorithm> is not set",0,"high","pass");
}

END {
}
