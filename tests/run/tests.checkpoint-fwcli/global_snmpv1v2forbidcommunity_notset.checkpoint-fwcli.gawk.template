#
# @test_name : global_snmpv1v2forbidcommunity_notset.checkpoint-fwcli.gawk
# @supplier : checkpoint-fwcli
# @purpose : check that <snmp v1v2 forbidden communities> are not set
# @description : well-known or forbidden snmp community strings expose the device to unauthorized monitoring and potential information disclosure
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AC-3 | Access Control | Ensure access enforcement is configured
# @risk_level : high
# @authors : maxime souris
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    delete VAR;
    pass = 1;
}

# var def ----
/^set[ \t]*\w+[ \t]*=/ {
    match($0, /^set[ \t]*(\w+)[ \t]*=/, var)
    VAR["$"var[1]] = $0;
    next;
}

# no var ----
/^set snmp community .*/ && $4 !~ /^\$\w+/ && $4 ~ /%SED_SNMP_FORBID_COMMUNITY%/ {
    print_err("global_snmpv1v2forbidcommunity_notset.checkpoint-fwcli.gawk","snmpv1v2 forbidden community <<"$0">>",FNR,"high","error");
    pass = 0;
    next
}
# no var ----

# var ----
/^set snmp community .*/ && $4 ~ /^\$\w+/ && VAR[$4] ~ /%SED_SNMP_FORBID_COMMUNITY%/ {
    print_err("global_snmpv1v2forbidcommunity_notset.checkpoint-fwcli.gawk","snmpv1v2 forbidden community <<"$0"/"VAR[$4]">>",FNR,"high","error");
    pass = 0;
    next
}
# var ----

ENDFILE {
    if (pass == 1) {
        print_err("global_snmpv1v2forbidcommunity_notset.checkpoint-fwcli.gawk","snmpv1v2 forbidden communities not set",0,"high","pass");
    }
}

END {
}
