#
# @test_name : global_snmpv1v2rw_notset.checkpoint-fwcli
# @supplier : checkpoint-fwcli
# @purpose : check that <snmp v1v2 write> is not set
# @description : snmp v1/v2 write communities allow unauthorized modification of device configuration and represent a critical security risk
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.2 | Ensure SNMPv3 with authentication | SNMP
# @authors : maxime souris
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 1;
}

/^set snmp community .*/ && $0 ~ /authorization/ && $0 !~ /read-only/ {
    print_err("global_snmpv1v2rw_notset.checkpoint-fwcli.gawk","snmpv1v2 write community <<"$0">>",FNR,"high","error");
    pass = 0;
    next;
}

ENDFILE {
    if (pass == 1) {
        print_err("global_snmpv1v2rw_notset.checkpoint-fwcli.gawk","snmpv1v2 write communities not set",0,"high","pass");
    }
}

END {
}
