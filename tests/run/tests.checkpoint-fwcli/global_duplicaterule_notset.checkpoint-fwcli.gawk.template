#
# @test_name : global_duplicaterule_notset.checkpoint-fwcli.gawk
# @supplier : checkpoint-fwcli
# @purpose : check that <duplicate rules> are not set
# @description : duplicate firewall rules indicate policy inconsistencies, increase rule base complexity, and may hide unintended access permissions
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : medium
# @authors : lucas vanhaaren
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# local functions ----
function processrule(rule,RULES) {
    if ( !(rule in RULES)) {
        RULES[rule] = 1
    } else {
        print_err("global_duplicaterule_notset.checkpoint-fwcli.gawk","duplicate rule detected <<"rule">>",FNR,"medium","error");
        pass = 0;
    }
}
# local functions ----

BEGIN {
}

BEGINFILE {
    delete RULES;
    pass = 1;
    rule = "";
}

# std rule ----
/^(add )?(access-|nat-)?rule / && !/\\$/ && rule == "" {
    processrule($0,RULES);
    next;
}
# std rule ----

# multi line rule ----
/^(add )?(access-|nat-)?rule / && /\\$/ && rule == "" {
    rule = rule $0;
    next;
}

/\\$/ && rule != "" {
    rule = rule $0;
    next;
}

!/\\$/ && rule != "" {
    rule = rule $0;
    processrule(rule,RULES);
    rule = "";
    next;
}
# multi line rule ----

ENDFILE {
    if ( pass ) {
        print_err("global_duplicaterule_notset.checkpoint-fwcli.gawk","no duplicate rules detected",FNR,"medium","pass");
    }
}

END {
}
