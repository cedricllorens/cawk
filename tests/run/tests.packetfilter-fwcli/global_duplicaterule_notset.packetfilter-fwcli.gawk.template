#
# @test_name : global_duplicaterule_notset.packetfilter-fwcli
# @supplier : packetfilter-fwcli
# @purpose : check that <duplicate rules> are not set
# @description : duplicate rules in packetfilter add unnecessary complexity and may indicate configuration drift or errors
# @actions : remove duplicate rules to simplify and clean up the ruleset (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.3 | Ensure no duplicate firewall rules | Firewall Policy
# @authors : lucas vanhaaren
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# local functions ----
function processrule(rule,RULES) {
    if ( !(rule in RULES)) {
        RULES[rule] = 1
    } else {
        print_err("global_duplicaterule_notset.packetfilter-fwcli.gawk","duplicate rule detected <<"rule">>",FNR,"medium","error");
        pass = 0;
    }
}
# local functions ----

BEGIN {
}

BEGINFILE {
    delete RULES;
    pass = 1;
    rule = "";
}

# std rule ----
$0 != "" && $0 ~ /^(pass|block) / && $0 !~ /\\$/ && rule == "" {
    processrule($0,RULES);
    next;
}
# std rule ----

# multi line rule ----
$0 ~ /^(pass|block) / && $0 ~ /\\$/ && rule == "" {
    rule = rule $0;
    next;
}

$0 ~ /\\$/ && rule != "" {
    rule = rule $0;
    next;
}

$0 !~ /\\$/ && rule != "" {
    rule = rule $0;
    processrule(rule,RULES);
    rule = "";
    next;
}
# multi line rule ----

ENDFILE {
    if ( pass ) {
        print_err("global_duplicaterule_notset.packetfilter-fwcli.gawk","no duplicate rules detected",FNR,"medium","pass");
    }
}

END {
}
