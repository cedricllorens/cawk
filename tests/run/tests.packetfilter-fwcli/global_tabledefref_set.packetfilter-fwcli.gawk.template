#
# @test_name : global_tabledefref_set.packetfilter-fwcli.gawk
# @supplier : packetfilter-fwcli
# @purpose : check <tables> def not ref and ref not def
# @description : tables defined but not referenced represent dead configuration; tables referenced but not defined cause rule processing errors
# @actions : align table definitions and references to ensure all tables are used and all references are valid (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SI-2 | System and Information Integrity | Ensure flaw remediation and patching is configured
# @risk_level : high | info
# @authors : pierre bertrand
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    delete TABLESDEF;
    delete TABLESREF;
}

# table def ----
/^table/ {
    TABLESDEF[$2] = $2;
    line_number[$2] = FNR;
    next;
}

# table ref ----
/.*<\w+>/ && !/^table/ {
    for (i=1;i<=NF;i++) {
        if($i ~ /<\w+>/) {
            TABLESREF[$i] = $i;
            if (line_number[$i]==""){
                line_number[$i] = FNR;
            } else {
                line_number [$i] = line_number[$i]" "FNR;
            }
        }
    }
    next;
}
 
ENDFILE {

    # table def and not ref ----
    pass = 1;
    for (id in TABLESDEF) {
        if (!(id in TABLESREF)) {
            print_err("global_tabledefref_set.packetfilter-fwcli.gawk","table def not ref "id"",line_number[id],"info","error");
            pass = 0;
        }
    }
    if (pass) print_err("global_tabledefref_set.packetfilter-fwcli.gawk","no table def not ref",0,"info","pass");

    # table ref and not def ----
    pass = 1;
    for (id in TABLESREF) {
        if (!(id in TABLESDEF)) {
            print_err("global_tabledefref_set.packetfilter-fwcli.gawk","table ref not def "id"",line_number[id],"high","error");
        }
    }
    if ( pass ) print_err("global_tabledefref_set.packetfilter-fwcli.gawk","no table ref not def",0,"high","pass");
}

END {
}
