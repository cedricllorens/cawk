#
# @test_name : global_lastruledrop_set.packetfilter-fwcli.gawk
# @supplier : packetfilter-fwcli
# @purpose : check <last drop rule> is set
# @description : missing last drop rule means traffic not matched by any explicit rule may be allowed by implicit accept
# @actions : add an explicit block rule as the last rule to enforce implicit deny (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : medium
# @authors : lucas vanhaaren
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    last_rule = "";
    rule = "";
}

# std rule ----
/^(pass|block) / && !/\\$/ {
    last_rule = $0;
    next;
}
# std rule ----

# multi line rule ----
/^(pass|block) / && /\\$/ && rule == "" {
    rule = rule $0;
    next;
}

/\\$/ && rule != "" {
    rule = rule $0;
    next;
}

!/\\$/ && rule != "" {
    rule = rule $0;
    last_rule = rule;
    rule = "";
    next;
}
# multi line rule ----

ENDFILE {
    if (tolower(last_rule) ~ /^block / ) {
        print_err("global_lastruledrop_set.packetfilter-fwcli.gawk","last rule is drop <<"last_rule">>",FNR,"medium","pass");
    } else {
        print_err("global_lastruledrop_set.packetfilter-fwcli.gawk","last rule is not drop <<"last_rule">>",FNR,"medium","error");
    }
}

END {
}

