#
# @test_name : global_rulelog_set.packetfilter-fwcli.gawk
# @supplier : packetfilter-fwcli
# @purpose : check that <rule log> is set globally
# @description : missing logging on firewall rules prevents tracking of allowed and denied traffic for security monitoring
# @actions : add logging to firewall rules to capture traffic events (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : medium
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# local functions ----
function processrule(rule) {

     if (rule ~ / log /) {
        print_err("global_rulelog_set.packetfilter-fwcli.gawk", "rule with logging <<"rule">>", FNR, "medium", "pass");
        pass = 0;
    }

}
# local functions ----

BEGIN {
}

BEGINFILE {
    rule = "";
    pass = 1;
}

# std line ----
/^(block|pass) / && !/\\$/{
  processrule($0);
  next;
}
# std line ----

# multi line rule ----
/^(block|pass) / && /\\$/ && rule == "" {
    rule = rule $0;
    next;
}

/\\$/ && rule != "" {
    rule = rule $0;
    next;
}

!/\\$/ && rule != "" {
    rule = rule $0;
    processrule(rule);
    rule = "";
    next;
}
# multi line rule ----

ENDFILE {
    if ( pass )  {
	    print_err("global_rulelog_set.packetfilter-fwcli.gawk","no rule with log is set",FNR,"medium","error");
    } 
}

END {
}
