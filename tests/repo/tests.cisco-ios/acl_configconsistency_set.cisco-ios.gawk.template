#
# for %SED_VAR% change like GAWK_PATH, etc. please refer to
# file support/tests.sed for further information
#
# purpose : check that <ip access-list standard ...> have inconsistent/redundant rules
# author  : cedric llorens
# ------------------------------------------------------------

# rule format ----------------------------------
# 1  rule_name          : string
# 2  rule_description   : string
# 3  action             : permit/deny
# 4  ingress/outgress   : "none","in","out","all"
# 5  interface          : "none",string
# 6  family             : "all", inet, inet6
# 7  src@               : ip
# 8  src_net@           : cird/netmask		set "none","host","any",[0-9]+,[0-9]+.[0-9]+.[0-9]+.[0-9]+
# 9  port_src           : port_src			set 0 if empty
# 10 port_src_range     : port_src_range	set 0 if empty
# 11 dst@               : ip				set 0 if empty
# 12 dst_net@           : cird/netmask		set "none","host","any",[0-9]+,[0-9]+.[0-9]+.[0-9]+.[0-9]+
# 13 port_dst           : port_dst			set 0 if empty
# 14 port_dst_range     : port_dst_range	set 0 if empty
# 15 protocol           : protocol			set "none" if empty
# rule format ----------------------------------

@include %SED_INCLUDE_PATH%
@include %SED_INCLUDE_PATH_FWLIB%

# ---------------------------------------------------------
# START
# ---------------------------------------------------------

BEGIN {
}

BEGINFILE {
	cawk_init_hypercube_rules();
	acl = "";
	check = 0;

	acl_simple = 0;
	block_acl = 0;
	block_acl_ext = 0;

}

# -----------------------------------------------------------
# SIMPLE ACL
# -----------------------------------------------------------
 
/^access-list [0-9]+ (permit|deny) ([0-9\.]+ [0-9\.]+|any)([ ]+log)?$/ {
	check = 1;
	acl_simple = 1;

	# rule name ----
	rule_desc = "rule_line_"FNR" <"$0">";

	if ( acl != $2 ) {
		if ( cawk_hypercube_rules_assessment() && acl != "" ) {
			print_err("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" has no redundant/inconsistent rules",FNR,"info","pass");
		}
		cawk_init_hypercube_rules();
	}
	
	acl = $2;
	
	if ( $4 =="any" ) {
		cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,$3,"none","none","all",$4,"any",0,0,0,0,0,0,"none")
	} else { 
		cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,$3,"none","none","all",$4,cawk_netMaskInv($5),0,0,0,0,0,0,"none")
	}
	next;
}

/^access-list [0-9]+ (permit|deny) ([0-9\.]+|any)([ ]+log)?$/ {
	check = 1;
	acl_simple = 1;
	rule_desc = "rule_line_"FNR" <"$0">";

	if ( acl != $2 ) {
		if ( cawk_hypercube_rules_assessment() && acl != "" ) {
			print_err("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" has no redundant/inconsistent rules",FNR,"info","pass");
		}
		cawk_init_hypercube_rules();
	}
	
	acl = $2;
	
	if ( $4 =="any" ) {
		cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,$3,"none","none","all",$4,"any",0,0,0,0,0,0,"none")
 	} else {
		cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,$3,"none","none","all",$4,"host",0,0,0,0,0,0,"none")
	}
	next;
}

/^(!|end)$/ && acl != "" && acl_simple == 1 {
	if ( cawk_hypercube_rules_assessment() ) {
		print_err("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" has no redundant/inconsistent rules",FNR,"info","pass");
	}
	
    cawk_init_hypercube_rules();
	acl = "";
	acl_simple = 0;
	next;
}

# -----------------------------------------------------------
# STANDARD BLOCK ACL
# -----------------------------------------------------------

/^ip access-list standard [^ ]+$/ {
	if ( cawk_hypercube_rules_assessment() && acl != "" ) {
		print_err("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" has no redundant/inconsistent rules",FNR,"info","pass");
	}

	cawk_init_hypercube_rules();
	acl = $4;
	block_acl = 1;
	check = 1;
}

/^[ ]([0-9]+ )?(permit|deny)[ ]+([0-9\.]+( [0-9\.]+)?|any)([ ]+log)?$/ && block_acl == 1 {

	# ruledesc ----
	rule_desc = "rule_line_"FNR" <"$0">";

	# rule numbering ---
	if ( $1 ~ /[0-9]+/ ) {
		local_current = 2;
	} else {
		local_current = 1;
	}

	# local action ----
	local_action = $local_current;
	local_current = local_current + 1;

	if ( $local_current == "any" ) {
		cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,local_action,"none","none","all",$local_current,$local_current,0,0,0,0,0,0,"none")
	} else {
		if ( $(local_current+1) != "" ) {
			cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,local_action,"none","none","all",$local_current,cawk_netMaskInv($(local_current+1)),0,0,0,0,0,0,"none")
		} else {
			cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,local_action,"none","none","all",$local_current,"host",0,0,0,0,0,0,"none")
		}
	}
	next;
}

/^(!|end)$/ && block_acl == 1 {
	if ( cawk_hypercube_rules_assessment() && acl != "" ) {
		print_err("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" has no redundant/inconsistent rules",FNR,"info","pass");
	}

	cawk_init_hypercube_rules();
	acl = "";
	block_acl = 0;
	next;
}

# -----------------------------------------------------------
# EXTENDED BLOCK ACL
# -----------------------------------------------------------

/^ip access-list extended [^ ]+$/ {
	if ( cawk_hypercube_rules_assessment() && acl != "" ) {
		print_err("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" has no redundant/inconsistent rules",FNR,"info","pass");
	}

	cawk_init_hypercube_rules();
	acl = $4;
	block_acl_ext = 1;
	check = 1;
}

/^[ ]([0-9]+[ ])?(permit|deny)[ ]+[a-z0-9]+[ ]+([0-9\.]+ [0-9\.]+|any|host [0-9\.]+)([ ]eq[ ][a-z0-9_-]+)?[ ](any|host|[0-9\.]+)/ && block_acl_ext == 1 {
	
	# ruledesc ----
	rule_desc = "rule_line_"FNR" <"$0">";

	# rule numbering ---
	if ( $1 ~ /[0-9]+/ ) {
		local_current = 2;
	} else {
		local_current = 1;
	}

	# action ----
	local_action = $local_current;
	local_current = local_current + 1;

	# protocol ----
	if (  $local_current == "ip" ) {
		local_protocol = "none";
	} else {
		local_protocol = $local_current;
	}
	local_current = local_current + 1;
	
	# src address ----
	if ( $local_current == "host" ) {

		local_src = $(local_current+1)
		local_src_net = "host"
		local_current = local_current + 2;
	
	} else if ( $local_current == "any" ) {

		local_src = $(local_current)
		local_src_net = $(local_current)
		local_current = local_current + 1;

	} else {

		local_src = $(local_current)
		local_src_net = cawk_netMaskInv($(local_current+1))
		local_current = local_current + 2;

	}

	# port src ----
	if ( $local_current == "eq" ) {

		if ( table_port[$(local_current+1)] == "" ) {
			local_port_src = $(local_current+1);
		} else {
			local_port_src = table_port[$(local_current+1)];
		}
		local_port_src_range = 0;
		local_current = local_current + 2;

	} else {
		
		local_port_src = 0;
		local_port_src_range = 0;
	
	}

	# dst address ----
	if ( $local_current == "host" ) {

		local_dst = $(local_current+1)
		local_dst_net = "host"
		local_current = local_current + 2;
	
	} else if ( $local_current == "any" ) {

		local_dst = $local_current
		local_dst_net = $local_current
		local_current = local_current + 1;

	} else {

		local_dst = $local_current
		local_dst_net = cawk_netMaskInv($(local_current+1))
		local_current = local_current + 2;

	}

	# port dst ----
	if ( $local_current == "eq" ) {

		if ( table_port[$(local_current+1)] == "" ) {
			local_port_dst = $(local_current+1);
		} else {
			local_port_dst = table_port[$(local_current+1)];
		}
		local_port_dst_range = 0;
		local_current = local_current + 2;

	} else {
		
		local_port_dst = 0;
		local_port_dst_range = 0;
	
	}

	cawk_add_hypercube_rules("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" "rule_desc,local_action,"none","none","all",local_src,local_src_net,local_port_src,local_port_src_range,local_dst,local_dst_net,local_port_dst,local_port_dst_range,local_protocol)
	next;
}

/^(!|end)$/ && block_acl_ext == 1 {
	if ( cawk_hypercube_rules_assessment() && acl != "" ) {
		print_err("acl_configconsistency_set.cisco-ios.gawk","access-list "acl" has no redundant/inconsistent rules",FNR,"info","pass");
	}

	cawk_init_hypercube_rules();
	acl = "";
	block_acl_ext = 0;
	next;
}

# ---------------------------------------------------------
# END
# ---------------------------------------------------------

ENDFILE { 
	if ( check == 0 ) print_err("acl_configconsistency_set.cisco-ios.gawk","no <ip access-list standard> found",FNR,"info","pass");
}
