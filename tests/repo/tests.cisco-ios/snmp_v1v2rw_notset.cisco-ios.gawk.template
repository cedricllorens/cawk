#
# @test_name : snmp_v1v2rw_notset.cisco-ios.gawk
# @supplier : cisco-ios
# @purpose : check if <snmp v1v2 rw> is not set
# @description : snmp v1/v2c read-write community string allows unauthorized configuration changes to the device
# @actions : remove rw community strings and use read-only community or migrate to snmp v3 (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AC-3 | Access Control | Ensure access enforcement is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^snmp-server community / && /RW/ {
	print_err("snmp_v1v2rw_notset.cisco-ios.gawk",$0,FNR,"high","error");
        pass = 0;
	nextfile;
}

ENDFILE {
        if ( pass ) print_err("snmp_v1v2rw_notset.cisco-ios.gawk","snmp v1v2 rw is not set",0,"high","pass");
}

END {
}
