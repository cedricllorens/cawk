#
# purpose : check if <service-password encryption> is set
# author  : cedric llorens
# @test_name : global_servicepassword_set.cisco-ios.gawk
# @supplier : cisco-ios
# @purpose : check if <service password-encryption> is set
# @description : service password encryption must be used to encrypt passwords in the configuration file
# @actions : set <service password-encryption> or remove it (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.2.2 | Ensure service password-encryption is set | Authentication
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
}

/^service password-encryption/ {
	print_err("global_servicepassword_set.cisco-ios.gawk",$0,FNR,"high","pass");
	pass = 1;
	nextfile;
}

ENDFILE {
	if ( !pass ) print_err("global_servicepassword_set.cisco-ios.gawk","<service password-encryption> is not set",0,"high","error");
}

END {
}
