#
# @test_name : fw_forbidproto_notset.fortinet-fortios.gawk
# @supplier : fortinet-fortios
# @purpose : check if a <firewall rule> implements forbidden protocols
# @description : firewall rules allowing forbidden protocols expand the attack surface and could expose the device to security risks
# @actions : remove or restrict firewall rules allowing forbidden protocols (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^config firewall policy/ {
	block_firewall = 1;
	next;
}

/^%SED_BK_FORTI%edit / && block_firewall == 1 {
	block_edit = 1;
	next;
}

/^%SED_BK_FORTI%{2}set service %SED_FORBIDPROTO_FORTI%/ && block_edit == 1 {
	print_err("fw_forbidproto_notset.fortinet-fortios.gawk",rm_blank_before($0),FNR,"high","error");
	pass = 0;
	next;
}

/^%SED_BK_FORTI%next$/ && block_edit == 1 {
	block_edit = 0;
	next;
}

/^end$/ && block_firewall == 1 {
	block_firewall = 0;
}

ENDFILE {
	if ( pass ) print_err("fw_forbidproto_notset.fortinet-fortios.gawk","firewall has no forbidden protocols",0,"high","pass");
}

END {
}
