#
# @test_name : int_mgnt_set.fortinet-fortios.gawk
# @supplier : fortinet-fortios
# @purpose : check if a <management interface> is set
# @description : missing dedicated management interface may expose management services on production interfaces
# @actions : configure a dedicated management interface with restricted access (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SI-2 | System and Information Integrity | Ensure flaw remediation and patching is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0 ;
	block_interface = 0;
}

/^config system interface/ {
	block_interface = 1;
	next;
}

/^%SED_BK_FORTI%edit / && /%SED_MGNT_KW%/ && block_interface == 1 {
	print_err("int_mgnt_set.fortinet-fortios.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 1;	
	next;
}

/^end$/ {
	block_interface = 0;
}

ENDFILE {
	if ( ! pass ) print_err("int_mgnt_set.fortinet-fortios.gawk","no mgnt interface is set",0,"high","error");
}

END {
}
