#
# @test_name : int_mgntforbidallow_notset.fortinet-fortios.gawk
# @supplier : fortinet-fortios
# @purpose : check if a <management interface> allows forbidden protocols
# @description : management interface allowing forbidden protocols expands the attack surface and could expose the device to security risks
# @actions : remove forbidden protocol permissions from the management interface (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.1 | Ensure interface rules are properly configured | Access Control
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1 ;
	block_interface = 0;
	block_edit = 0;
}

/^config system interface/ {
	block_interface = 1;
	next;
}

/^%SED_BK_FORTI%edit / && /%SED_MGNT_KW%/ && block_interface == 1 {
	block_edit = 1;
	block_edit_str = rm_blank_before($0);
	next;
}

/^%SED_BK_FORTI%{2}[ ]*set allowaccess / && /%SED_MGNT_BADPROTO%/ && block_edit == 1 {
	print_err("int_mgntforbidallow_notset.fortinet-fortios.gawk",block_edit_str" "rm_blank_before($0),0,"high","error");
	pass = 0;
	next;
}

/^%SED_BK_FORTI%next$/ && block_edit == 1 {
	block_edit = 0;
	next;
}

/^end$/ {
	block_edit = 0;
	block_interface = 0;
}

ENDFILE {
	if ( pass ) print_err("int_mgntforbidallow_notset.fortinet-fortios.gawk","mngt interface without forbidden protocols",0,"high","pass");
}

END {
}
