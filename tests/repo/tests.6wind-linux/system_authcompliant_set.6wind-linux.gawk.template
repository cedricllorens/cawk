#
# @test_name : system_authcompliant_set.6wind-linux.gawk
# @supplier : 6wind-linux
# @purpose : check if <system><auth> block is compliant (trusted users)
# @description : non-compliant authentication configuration allowing untrusted users could grant unauthorized access to the device
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.1.2 | Ensure authentication is properly configured | System Administration
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    pass = 1;
    block = 0;
}

/^system$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%auth$/ && block {
    block = 2;
    next;
}

/^%SED_BK_WIND%{2}user[ ]/ && block == 2 {
    if (!match($0, /(admin)$/)) {
        print_err("system_authcompliant_set.6wind-linux.gawk", "<system><auth> block not compliant / bad user : "rm_blank_before($0), FNR, "high", "error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%(\.\.|exit|[^ ])/ {
    block = 1;
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
    next;
}

ENDFILE {
    if (pass) {
        print_err("system_authcompliant_set.6wind-linux.gawk", "<system><auth> block is compliant", FNR, "high", "pass");
    }
}

END {
}

