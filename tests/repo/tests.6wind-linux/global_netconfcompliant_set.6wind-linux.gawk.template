#
# @test_name : global_netconfcompliant_set.6wind-linux.gawk
# @supplier : 6wind-linux
# @purpose : check if <vrf main><netconf-server> block is compliant (address, enabled true)
# @description : non-compliant NETCONF server configuration (bad address, missing port, or service disabled) could expose the device to unauthorized management access
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.2.1 | Ensure NETCONF is securely configured | Management Access
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    enable = 1;
    pass = 1;
    block = 0;
}

/^vrf main$/ {
    block = 1;
    next;
}

/^%SED_BK_WIND%netconf-server$/ && block {
    block = 2;
    next;
}

/^%SED_BK_WIND%{2}address .*$/ && block == 2 {
    if (!match($0, /^[ ]{8}address [0-9]+\.[0-9]+\.[0-9]+\.[0-9]+[ ]/)) {
        print_err("global_netconfcompliant_set.6wind-linux.gawk", "<vrf main><netconf-server> block not compliant / bad address : "rm_blank_before($0), FNR, "high", "error");
        pass = 0;
    }
    if (!match($0, /port [0-9]+$/)) {
        print_err("global_netconfcompliant_set.6wind-linux.gawk", "<vrf main><netconf-server> block not compliant / bad port : "rm_blank_before($0), FNR, "high","error");
        pass = 0;
    }
    next;
}

/^%SED_BK_WIND%{2}enabled true$/ && block == 2 {
    enable = 0;
    next;
}

/^%SED_BK_WIND%(\.\.|exit|[^ ])/ {
    block = 1;
    next;
}

/^(\.\.|exit|[^ ])/ {
    block = 0;
    next;
}

ENDFILE {
    if (enable) {
        print_err("global_netconfcompliant_set.6wind-linux.gawk", "<vrf main><netconf-server> block not compliant / enabled true is not set", FNR, "high", "error");
        pass = 0;
    }
    if (pass) {
        print_err("global_netconfcompliant_set.6wind-linux.gawk", "<vrf main><netconf-server> block is compliant", FNR, "high", "pass");
    }
}

END {
}

