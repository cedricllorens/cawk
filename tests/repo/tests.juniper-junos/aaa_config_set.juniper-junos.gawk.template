#
# @test_name : aaa_config_set.juniper-junos.gawk
# @supplier : juniper-junos
# @purpose : check if <aaa config> is set
# @description : missing aaa configuration means authentication, authorization, and accounting are not properly enforced
# @actions : configure aaa with proper authentication and authorization settings (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.1 | Ensure AAA is configured | System Access, Authentication, and Authorization
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
	block_system = 0;
}

/^system {/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_JUNI%%SED_AAASYSTEM_JUNI%/ && block_system == 1 && !/inactive/ {
	print_err("aaa_config_set.juniper-junos.gawk",rm_blank_before($0),FNR,"high","pass");
        pass = 1;
	nextfile;	
}

/^}$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( ! pass ) print_err("aaa_config_set.juniper-junos.gawk","aaa config is not set",0,"high","error");
}

END {
}
