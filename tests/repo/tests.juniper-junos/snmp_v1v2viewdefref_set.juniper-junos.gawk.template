#
# @test_name : snmp_v1v2viewdefref_set.juniper-junos.gawk
# @supplier : juniper-junos
# @purpose : check when <view> def and not ref / check when <view> ref and not def
# @description : SNMP view defined but not referenced represents dead configuration; view referenced but not defined causes SNMP policy errors and access failures
# @actions : align SNMP view definitions and references to ensure all views are used and all references are valid (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AC-3 | Access Control | Ensure access enforcement is configured
# @risk_level : high | info
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	delete view_def;
	delete view_ref;
}

# def ----

/^snmp {/ && !/inactive/ {
	in_snmp = 1;
	next;
}

in_snmp && /^%SED_BK_JUNI%view [^ ]+ {/ && !/inactive/ {
	if ( $2 !~ /^"?\$/ ) view_def[$2] = rm_last_char(rm_blank_before($0));
	next;
}

# ref ----

in_snmp && /^%SED_BK_JUNI%community [^ ]+ {/ && !/inactive/ {
	in_community = 1;
	next;
}

in_community && /^%SED_BK_JUNI%%SED_BK_JUNI%view [^ ]+;/ && !/inactive/ {
	view_ref_name = rm_last_char($2);
	if ( view_ref_name !~ /^"?\$/ ) view_ref[view_ref_name] = rm_last_char(rm_blank_before($0));
	next;
}

/^}$/ && in_snmp && !in_community {
	in_snmp = 0;
}

/^%SED_BK_JUNI%}$/ && in_community {
	in_community = 0;
}

ENDFILE {

	# view def and not ref ----
	for (id in view_def) {
		if ( !(id in view_ref) ) {
			print_err("snmp_v1v2viewdefref_set.juniper-junos.gawk",id" : view def but not ref :"view_def[id],0,"info","error");
			pass = 0;
		}
	}

	# view ref and not def ----
	for (id in view_ref) {
		if ( !(id in view_def) ) {
			print_err("snmp_v1v2viewdefref_set.juniper-junos.gawk",id" : view ref but not def :"view_ref[id],0,"high","error");
			pass = 0;
		}
	}

	if ( pass ) print_err("snmp_v1v2viewdefref_set.juniper-junos.gawk","all view defs are refs and the reverse",0,"high","pass");
}

END {
}
