#
# @test_name : snmp_v1v2rw_notset.juniper-junos.gawk
# @supplier : juniper-junos
# @purpose : check if <snmp v1v2 write> is not set
# @description : snmp v1v2 read-write community strings allow configuration changes via an insecure protocol
# @actions : disable snmp v1v2 read-write access and use snmp v3 with appropriate privileges (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.6.2 | Ensure SNMPv3 with authentication | SNMP
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_snmp = 0;
}

/^snmp {/ {
	block_snmp = 1;
	block_community = 0;
	next;
}

/^%SED_BK_JUNI%community / && block_snmp == 1 {
	block_community = 1;
	next;
}

/^%SED_BK_JUNI%{2}authorization write/ && block_community == 1 {
	print_err("snmp_v1v2rw_notset.juniper-junos.gawk",rm_blank_before(rm_last_char($0)),FNR,"high","error");
        pass = 0;
	nextfile;
}

/^%SED_BK_JUNI%}$/ && block_community == 1 {
	block_community = 0;
	next;
}

/^}/ {
	block_snmp = 0;
}

ENDFILE {
        if ( pass ) print_err("snmp_v1v2rw_notset.juniper-junos.gawk","snmp v1v2 write is not set",0,"high","pass");
}

END {
}
