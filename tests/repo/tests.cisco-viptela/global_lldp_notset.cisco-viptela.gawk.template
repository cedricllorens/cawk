# file support/tests.sed for further information
#
# @test_name : global_lldp_notset.cisco-viptela.gawk
# @supplier : cisco-viptela
# @purpose : check if a <lldp/cdp> is not set
# @description : lldp/cdp can be used to gain unauthorized access to the device or reveal sensitive information
# @actions : set <no lldp run> or disable cdp (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^[ ]*(cdp|lldp) enable/ {
	print_err("global_lldp_notset.cisco-viptela.gawk",$0,FNR,"high","error");
    pass = 0;
	nextfile;
}

ENDFILE {
    if ( pass ) print_err("global_lldp_notset.cisco-viptela.gawk","<cdp/ldp> is not set",0,"high","pass");
}

END {
}
