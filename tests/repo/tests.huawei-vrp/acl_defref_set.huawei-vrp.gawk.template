#
# @test_name : acl_defref_set.huawei-vrp.gawk
# @supplier : huawei-vrp
# @purpose : check when an <acl> is def and not ref / check when an <acl> is ref and not def
# @description : acl defined but not referenced represents dead configuration; acl referenced but not defined causes policy errors
# @actions : align acl definitions and references to ensure all acls are used and all references are valid (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.1 | Ensure ACL definitions are referenced | Access Control
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	delete acl_def;
	delete acl_ref;
}

# def ----

/^acl number [^ ]+.*$/ {
	acl_def[$3] = $0;
	next;
}

# ref ----

/^[ ]*acl [^ ]+ (inbound|outbound)$/ {
	acl_ref[$2] = $0;
	next;
}

/^[ ]*packet-filter inbound acl [^ ]+.*$/ {
	acl_ref[$4] = $0;
}

/^[ ]*snmp-agent (group|community) .* acl [^ ]+.*$/ {
	acl_ref[$NF] = $0;
}

/^[ ]*if-match acl [^ ]+.*$/ {
	acl_ref[$3] = $0;
}

/^[ ]*tftp-server acl [^ ]+.*$/ {
	acl_ref[$3] = $0;
}

ENDFILE {

	# acl def not ref ----
	for (id in acl_def) {
		if ( !(id in acl_ref) ) {
			print_err("acl_defref_set.huawei-vrp.gawk",id" : def not ref :"acl_def[id],0,"info","error");
			pass = 0;
		}
	}

	# acl ref not def ----
	for (id in acl_ref) {
		if ( !(id in acl_def) ) {
			print_err("acl_defref_set.huawei-vrp.gawk",id" : ref not def :"acl_ref[id],0,"high","error");
			pass = 0;
		}
	}

	if ( pass ) print_err("acl_defref_set.huawei-vrp.gawk","all acls defs are refs and the reverse",0,"high","pass");
}

END {
}
