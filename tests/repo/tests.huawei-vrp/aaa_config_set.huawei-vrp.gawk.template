#
# @test_name : aaa_config_set.huawei-vrp.gawk
# @supplier : huawei-vrp
# @purpose : check if <aaa config> is set
# @description : missing aaa configuration means authentication, authorization, and accounting are not properly enforced
# @actions : configure aaa with proper authentication and authorization settings (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : IA-2 | Identification and Authentication | Ensure unique identification and authentication of organizational users is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
}

/^aaa$/ {
	print_err("aaa_config_set.huawei-vrp.gawk",$0,FNR,"high","pass");
	pass = 1;
	nextfile;
}

ENDFILE {
	if ( !pass ) print_err("aaa_config_set.huawei-vrp.gawk","aaa config is not set",0,"high","error");
}

END {
}
