#
# @test_name : global_rcmd_notset.huawei-vrp.gawk
# @supplier : huawei-vrp
# @purpose : check if <rcmd server> is not set
# @description : rcmd server enables insecure remote command execution services that should not be active on network devices
# @actions : disable rcmd server to prevent insecure remote access (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.5 | Ensure RCMD is disabled | Network Protocols
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1 ;
}

/^rcmd(s)? server enable/ {
	print_err("global_rcmd_notset.huawei-vrp.gawk",$0,FNR,"high","error");
	pass = 0;
	nextfile;
}

ENDFILE {
	if ( pass ) print_err("global_rcmd_notset.huawei-vrp.gawk","rcmd server is not set",0,"high","pass");
}

END {
}
