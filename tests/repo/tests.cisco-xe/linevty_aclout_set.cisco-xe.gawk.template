#
# @test_name : linevty_aclout_set.cisco-xe.gawk
# @supplier : cisco-xe
# @purpose : check if a line vty has <access-class xx out>
# @description : line vty without outbound ACL can allow unauthorized outgoing remote management connections from the device
# @actions : set <access-class xx out> on line vty (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.4.4 | Ensure VTY lines have ACLs | Console and Line Access
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( aclout == 0 ) {
		print_err("linevty_aclout_set.cisco-xe.gawk",linevty" : acl out missing",linenovty,"high","error");
		pass = 0;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block_vty = 0;
	pass = 1;
}

/^line vty .*$/ {
	if ( block_vty == 1 ) acl_summary();
	linevty = $0;
	linenovty = FNR;
	aclout = 0;
        block_vty = 1;
	next;
}

/^ access-class .* out/ && block_vty == 1 {
	aclout = 1;
	next;
}

/^!$/ && block_vty == 1 {
	acl_summary();
	block_vty = 0;
}

ENDFILE {
	if ( pass ) print_err("linevty_aclout_set.cisco-xe.gawk","line vty acls out are set",0,"high","pass");
}

END {
}
