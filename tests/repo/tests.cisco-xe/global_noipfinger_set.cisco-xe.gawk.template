#
# @test_name : global_noipfinger_set.cisco-xe.gawk
# @supplier : cisco-xe
# @purpose : check if <no ip finger> is set and <ip finger> is not set
# @description : ip finger can be used to gain unauthorized access to the device or reveal sensitive information
# @actions : set <no ip finger> or remove <ip finger> (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

/^no ip finger/ {
	print_err("global_noipfinger_set.cisco-xe.gawk",$0,FNR,"high","pass");
	pass = 0;
	next;
}

/^ip finger/ {
	print_err("global_noipfinger_set.cisco-xe.gawk","<ip finger> is set",0,"high","error");
	pass = 2;
	next;
}

ENDFILE {
	if ( pass == 1 ) print_err("global_noipfinger_set.cisco-xe.gawk","<no ip finger> is set by default",0,"high","pass");
}

END {
}
