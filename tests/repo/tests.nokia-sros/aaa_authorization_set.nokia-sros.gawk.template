#
# @test_name : aaa_authorization_set.nokia-sros.gawk
# @supplier : nokia-sros
# @purpose : check if <aaa authorization> is set
# @description : missing aaa authorization means privilege levels and command access are not centrally controlled
# @actions : configure aaa authorization to enforce role-based access control (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : IA-2 | Identification and Authentication | Ensure unique identification and authentication of organizational users is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
	block_system = 0;
	block_security = 0;
	block_aaa = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}security/ && block_system == 1 {
	block_security = 1;
	next;
}

/^%SED_BK_NOKIA%{3}%SED_AAASYSTEM_NOKIA%/ && block_security == 1 {
	block_aaa = 1;
	next;
}

/^%SED_BK_NOKIA%{4}authorization/ && block_aaa == 1 {
	print_err("aaa_authorization_set.nokia-sros.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 1;
	nextfile;
}

/^%SED_BK_NOKIA%{3}exit$/ && block_aaa == 1 {
	block_aaa = 0;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_security == 1 {
	block_security = 0;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
}

ENDFILE {
        if ( ! pass ) print_err("aaa_authorization_set.nokia-sros.gawk","aaa authorization is not set",0,"high","error");
}

END {
}
