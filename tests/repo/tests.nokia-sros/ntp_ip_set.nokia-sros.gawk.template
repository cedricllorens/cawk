#
# @test_name : ntp_ip_set.nokia-sros.gawk
# @supplier : nokia-sros
# @purpose : check if <ntp server ip> is set
# @description : missing ntp server configuration means the device clock may drift, causing log timestamp inconsistencies and authentication issues
# @actions : configure ntp server ip addresses to synchronize device time (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 3.2.1 | Ensure NTP is configured | Logging and Timestamping
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
	block_system = 0;
	block_time = 0;
	block_ntp = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}time/ && block_system == 1 {
	block_time = 1;
	next;
}

/^%SED_BK_NOKIA%{3}ntp/ && block_time == 1 {
	block_ntp = 1;
	next;
}

/^%SED_BK_NOKIA%{4}server [0-9\0]+/ && block_ntp == 1 {
	print_err("ntp_ip_set.nokia-sros.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 1;
	nextfile;
}

/^%SED_BK_NOKIA%{3}exit$/ && block_ntp == 1 {
	block_ntp = 0;
	next;
}

/^%SED_BK_NOKIA%{2}exit$/ && block_time == 1 {
	block_time = 0;
	next;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
	next;
}

ENDFILE {
        if ( !pass ) print_err("ntp_ip_set.nokia-sros.gawk","<ntp server ip> is not set",0,"high","error");
}

END {
}
