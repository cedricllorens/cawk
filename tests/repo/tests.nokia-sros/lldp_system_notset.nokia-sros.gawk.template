#
# @test_name : lldp_system_notset.nokia-sros.gawk
# @supplier : nokia-sros
# @purpose : check if <lldp> at system is not set
# @description : lldp enabled at the system level discloses network topology information to adjacent devices and may be exploited
# @actions : disable lldp at the system level if not required for network operations (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.2.2 | Ensure LLDP/CDP is disabled | Network Protocols
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
	block_system = 0;
}

/^%SED_BK_NOKIA%system/ && block_system == 0 {
	block_system = 1;
	next;
}

/^%SED_BK_NOKIA%{2}lldp/ && block_system == 1 {
	print_err("lldp_system_notset.nokia-sros.gawk",rm_blank_before($0),FNR,"high","pass");
	pass = 0;
	next;
}

/^%SED_BK_NOKIA%exit$/ && block_system == 1 {
	block_system = 0;
	next;
}

ENDFILE {
        if ( pass ) print_err("lldp_system_notset.nokia-sros.gawk","<lldp> is not set",0,"high","pass");
}

END {
}
