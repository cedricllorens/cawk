#
# @test_name : global_forbidbeforerule_notset.packetfilter-fwcli.gawk
# @supplier : packetfilter-fwcli
# @purpose : check if <pass/block> are defined before nat/rdr/match/scrub
# @description : pass/block rules defined before nat/rdr/match/scrub rules may be shadowed or cause unexpected policy behavior
# @actions : reorder rules to ensure pass/block rules are placed after nat/rdr/match/scrub rules as required by pf rule evaluation order (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.3.2 | Ensure forbidden rules are not present | Firewall Policy
# @authors : adrien lebout, pierre bertrand
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	passblock = 0;
	pass = 0;
}

/^(pass|block)/ {
	passblock = 1;
	next;
}

/^(rdr|nat|match|scrub)/ && passblock {
	print_err("global_forbidbeforerule_notset.packetfilter-fwcli.gawk","block/pass rules written before <<"$0">>",FNR,"medium","error");
	pass = 1;
	next;
}

ENDFILE {
	if ( pass == 0 || ( pass == 1 && passblock == 0) ) {
		print_err("global_forbidbeforerule_notset.packetfilter-fwcli.gawk","no block/pass rule written before nat/rdr/match/scrub",0,"medium","pass");
	}
}

END {
}
