#
# @test_name : global_basicrulecheck_set.packetfilter-fwcli.gawk
# @supplier : packetfilter-fwcli
# @purpose : check basic tests on rules
# @description : basic rule quality checks detect common misconfigurations and policy gaps in the packetfilter ruleset
# @actions : review and correct rules that fail basic quality checks (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SI-2 | System and Information Integrity | Ensure flaw remediation and patching is configured
# @risk_level : high
# @authors : adrien lebout
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 1;
}

# check block option ----
/^block[ ]/ && $2 !~/^(in|out|all|return|quick|drop|log)$/ {
	print_err("global_basicrulecheck_set.packetfilter-fwcli.gawk","block option error <<"$0">>",FNR,"high","error");
	pass = 0;
	next;
}

# check pass option ----
/^pass[ ]/ && $2 !~/^(in|inet|out|all|log|quick)$/ {
	print_err("global_basicrulecheck_set.packetfilter-fwcli.gawk","pass option error <<"$0">>",FNR,"high","error");
	pass = 0;
	next;
}

# check scrub option ----
/^scrub[ ]/ && $2 !~/^(in|out|all|on|reassemble|fragment)$/ {
	print_err("global_basicrulecheck_set.packetfilter-fwcli.gawk","scrub option error <<"$0">>",FNR,"high","error");
	pass = 0;
	next;
}

ENDFILE {
	if ( pass ) print_err("global_basicrulecheck_set.packetfilter-fwcli.gawk","all rules are correct",0,"high","pass");
}

END {
}
