#
# @test_name : login_banner_set.paloalto-panos.gawk
# @supplier : paloalto-panos
# @purpose : check if <login-banner> is set
# @description : missing login banner deprives the organisation of the legal notice required to warn unauthorized users and to support prosecution of unauthorized access
# @actions : configure a login-banner with an explicit authorized-use legal notice (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : AC-8 | Access Control | Ensure system use notification is displayed before granting access
# @risk_level : medium
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
}

/^%SED_BK_PALO%system/ {
	block_system = 1;
	next;
}

/^%SED_BK_PALO%{2}login-banner/ && block_system == 1 {
	print_err("login_banner_set.paloalto-panos.gawk",rm_blank_before($0),FNR,"medium","pass");
	pass = 1;
	next;
}

/^%SED_BK_PALO%\}/ && block_system == 1 {
	block_system = 0;
	next;
}

ENDFILE {
	if ( !pass ) print_err("login_banner_set.paloalto-panos.gawk","login-banner is not set",0,"medium","error");
}

END {
}
