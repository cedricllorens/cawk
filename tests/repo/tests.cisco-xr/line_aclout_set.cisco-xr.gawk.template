#
# @test_name : line_aclout_set.cisco-xr.gawk
# @supplier : cisco-xr
# @purpose : check if a line vty has <access-class xx out>
# @description : line vty without outbound ACL can allow unauthorized outgoing remote management connections from the device
# @actions : set <access-class xx out> on line vty (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.4.1 | Ensure terminal lines have ACLs | Console and Line Access
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( aclout == 0 ) {
		print_err("line_aclout_set.cisco-xr.gawk",line" : acl out missing",linenovty,"high","error");
		pass = 0;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block = 0;
	pass = 1;
}

/^line .*$/ && !/console/ {
	if ( block == 1 ) acl_summary();
	line = $0;
	linenovty = FNR;
	aclout = 0;
        block = 1;
	next;
}

/^ access-class outgress .*/ && block == 1 {
	aclout = 1;
	next;
}

/^!$/ && block == 1 {
	acl_summary();
	block = 0;
}

ENDFILE {
	if ( pass ) print_err("line_aclout_set.cisco-xr.gawk","line vty acls out are set",0,"high","pass");
}

END {
}
