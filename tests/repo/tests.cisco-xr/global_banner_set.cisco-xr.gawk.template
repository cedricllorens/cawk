#
# @test_name : global_banner_set.cisco-xr.gawk
# @supplier : cisco-xr
# @purpose : check if <banner motd/login/exec> are set
# @description : banners can be used to display important information to users
# @actions : set banners (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 2.4.1 | Ensure login banner is configured | Banner & Notification
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	banner_set = 0;
}

/^banner[ \t]+(login|exec|motd|incoming)/ {
	banner_set = 1;
	nextfile;
}

ENDFILE {
	if (banner_set)
		print_err("global_banner_set.cisco-xr.gawk", "<banner login/exec/motd> is set", 0, "high", "pass");
	else
		print_err("global_banner_set.cisco-xr.gawk", "<banner login/exec/motd> is not set", 0, "high", "error");
}

END {
}
