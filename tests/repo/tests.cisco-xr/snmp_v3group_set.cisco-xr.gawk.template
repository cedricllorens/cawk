#
# @test_name : snmp_v3group_set.cisco-xr.gawk
# @supplier : cisco-xr
# @purpose : check if <snmp v3 group priv> is set
# @description : missing snmp v3 group with priv security level means snmp v3 authentication and encryption are not enforced at the group level, weakening snmp access control
# @actions : configure <snmp-server group> with v3 priv to enforce both authentication and encryption for all snmp v3 access (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : IA-2 | Identification and Authentication | Ensure unique identification and authentication of organizational users is configured
# @risk_level : high
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
	pass = 0;
}

/^snmp-server group \w+ v3 priv/ {
	print_err("snmp_v3group_set.cisco-xr.gawk",$0,FNR,"high","pass");
	pass = 1;
	nextfile;
}

ENDFILE {
	if ( !pass ) print_err("snmp_v3group_set.cisco-xr.gawk","no snmp v3 group with priv level is set",0,"high","error");
}

END {
}
