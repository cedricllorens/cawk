#
# @test_name : line_aclin_set.cisco-xr.gawk
# @supplier : cisco-xr
# @purpose : check if a line vty has <access-class xx in>
# @description : line vty without inbound ACL can allow unauthorized remote management access from any source
# @actions : set <access-class xx in> on line vty (please refer to engineering/operations guidelines for further information)
# @cis_benchmark_ref : 1.4.1 | Ensure terminal lines have ACLs | Console and Line Access
# @authors : cedric llorens
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

# ----

function acl_summary() {
	if ( aclin == 0 ) {
		print_err("line_aclin_set.cisco-xr.gawk",line" : acl in missing",lineno,"high","error");
		pass = 0;
	}
}

# ----

BEGIN {
}

BEGINFILE {
	block = 0;
	pass = 1;
}

/^line .*$/ && !/console/ {
	if ( block == 1 ) acl_summary();
	line = $0;
	lineno = FNR;
	aclin = 0;
        block = 1;
	next;
}

/^ access-class ingress .*/ && block == 1 {
	aclin = 1;
	next;
}

/^!$/ && block == 1 {
	acl_summary();
	block = 0;
}

ENDFILE {
	if ( pass ) print_err("line_aclin_set.cisco-xr.gawk","line  acls in are set",0,"high","pass");
}

END {
}
