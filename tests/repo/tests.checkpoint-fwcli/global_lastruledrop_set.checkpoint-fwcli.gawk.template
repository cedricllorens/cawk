#
# @test_name : global_lastruledrop_set.checkpoint-fwcli.gawk
# @supplier : checkpoint-fwcli
# @purpose : check <last drop rule> is set
# @description : a missing implicit deny-all last rule may allow unintended traffic to pass through the firewall policy
# @actions : missing statements should be added to the configuration or setup exceptions (please refer to engineering/operations guidelines for further information)
# @nist800-53_ref : SC-7 | System and Communications Protection | Ensure boundary protection is configured
# @risk_level : medium
# @authors : lucas vanhaaren
# ------------------------------------------------------------

@include %SED_INCLUDE_PATH%

BEGIN {
}

BEGINFILE {
    last_rule = "";
    rule = "";
}

# std rule ----
/^(add )?(access-|nat-)?rule / && !/\\$/ {
    last_rule = $0;
    next;
}
# std rule ----

# multi line rule ----
/^(add )?(access-|nat-)?rule / && /\\$/ && rule == "" {
    rule = rule $0;
    next;
}

/\\$/ && rule != "" {
    rule = rule $0;
    next;
}

!/\\$/ && rule != "" {
    rule = rule $0;
    last_rule = rule;
    rule = "";
    next;
}
# multi line rule ----

ENDFILE {
    if (tolower(last_rule) ~ /action/ && tolower(last_rule) ~ /drop/) {
        print_err("global_lastruledrop_set.checkpoint-fwcli.gawk","last rule is drop <<"last_rule">>",FNR,"medium","pass");
    } else {
        print_err("global_lastruledrop_set.checkpoint-fwcli.gawk","last rule is not drop <<"last_rule">>",FNR,"medium","error");
    }
}

END {
}

